<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Company>Griffins</Company>
    <Copyright>Copyright © Griffins 2025</Copyright>
    <AssemblyVersion>7.1.0.0</AssemblyVersion>
    <FileVersion>7.1.0.0</FileVersion>
    <AssemblyTitle>Griffins.Map.UIDataObj.Simple</AssemblyTitle>
    <Product>Griffins.Map.UIDataObj.Simple</Product>
    <TargetFramework>net9.0</TargetFramework>
    <OutputType>Library</OutputType>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <OutputPath>F:\Griffins7.1\Bin\Share\Map\UIDataObj\</OutputPath>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Griffins.ImeIOT" Version="7.1.0">
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Griffins.Map2\Griffins.Map2.csproj">
      <Private>False</Private>
      <ExcludeAssets>runtime</ExcludeAssets>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <Compile Update="ResourceNames.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>ResourceNames.resx</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="ResourceNames.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>ResourceNames.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>
