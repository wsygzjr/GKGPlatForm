<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	  <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
	  <OutputPath>F:\Griffins7.1\Bin\Share\Map\PageFrameTemplate</OutputPath>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Assets\Icons\DefaultGotoParentPage.png" />
    <None Remove="Assets\Icons\DefaultGotoRootPage.png" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Assets\Icons\DefaultGotoParentPage.png" />
    <EmbeddedResource Include="Assets\Icons\DefaultGotoRootPage.png" />
  </ItemGroup>
	<ItemGroup>
		<PackageReference Include="Avalonia" Version="11.3.3" />
		<PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.3" />
		<PackageReference Include="Avalonia.Fonts.Inter" Version="11.3.3" />
		<PackageReference Include="Avalonia.ReactiveUI" Version="11.3.3" />
		<PackageReference Include="Griffins.Map.UI" Version="7.1.0" />
	</ItemGroup>
	<ItemGroup>
	  <Compile Update="ResourceString.Designer.cs">
	    <DependentUpon>ResourceString.resx</DependentUpon>
	    <DesignTime>True</DesignTime>
	    <AutoGen>True</AutoGen>
	  </Compile>
	  <Compile Update="Views\ConfigWindow.axaml.cs">
	    <DependentUpon>ConfigWindow.axaml</DependentUpon>
	  </Compile>
	  <Compile Update="Views\Menu\PageToolBarButtonView.axaml.cs">
	    <DependentUpon>PageToolBarButtonView.axaml</DependentUpon>
	  </Compile>
	  <Compile Update="Views\Menu\TopMenuView.axaml.cs">
	    <DependentUpon>TopMenuView.axaml</DependentUpon>
	  </Compile>
	  <Compile Update="Views\PreviewView.axaml.cs">
	    <DependentUpon>PreviewView.axaml</DependentUpon>
	  </Compile>
	</ItemGroup>
	<ItemGroup>
	  <EmbeddedResource Update="ResourceString.resx">
	    <LastGenOutput>ResourceString.Designer.cs</LastGenOutput>
	    <Generator>ResXFileCodeGenerator</Generator>
	  </EmbeddedResource>
	</ItemGroup>
  <!-- 自定义目标：清理输出 -->
  <Target Name="CleanOutputDependencies" AfterTargets="Build">
    <ItemGroup>
      <!-- 要删除的 DLL 文件 -->
      <DllsToDelete Include="$(OutputPath)Griffins.Map.UI.dll" />
      <DllsToDelete Include="$(OutputPath)Griffins.Map2.dll" />
      <DllsToDelete Include="$(OutputPath)Griffins.UI2.dll" />

      <!-- 要删除的 PDB 文件 -->
      <PdbsToDelete Include="$(OutputPath)Griffins.Map.UI.pdb" />
      <PdbsToDelete Include="$(OutputPath)Griffins.Map2.pdb" />
      <PdbsToDelete Include="$(OutputPath)Griffins.UI2.pdb" />

      <!-- 要删除的 XML 文件 -->
      <XmlsToDelete Include="$(OutputPath)Griffins.Map.UI.xml" />
      <XmlsToDelete Include="$(OutputPath)Griffins.Map2.xml" />
      <XmlsToDelete Include="$(OutputPath)Griffins.UI2.xml" />

      <!-- 合并所有要删除的文件 -->
      <AllFilesToDelete Include="@(DllsToDelete)" />
      <AllFilesToDelete Include="@(PdbsToDelete)" />
      <AllFilesToDelete Include="@(XmlsToDelete)" />
    </ItemGroup>
    <!-- 删除文件 -->
    <Delete Files="@(AllFilesToDelete)" ContinueOnError="true" />
  </Target>
</Project>
