<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NonMainFrameViewModel.ViewModels.ToolbarMenu;assembly=NonMainFrame"
             xmlns:vmComon="clr-namespace:NonMainFrameViewModel.ViewModels.Comon;assembly=NonMainFrame"
             xmlns:vmMap="clr-namespace:Griffins.Map.UI;assembly=Griffins.Map.UI"
             xmlns:converter="clr-namespace:NonMainFrameView.Converter"
             x:Class="NonMainFrameView.Views.Menu.PageToolBarButtonView"
             mc:Ignorable="d"
             x:DataType="vm:PageToolBarButtonViewModel"
             d:DesignWidth="800" d:DesignHeight="60">
	
	<Design.DataContext>
		<vm:PageToolBarButtonViewModel />
	</Design.DataContext>
	
	<UserControl.Resources>
		<converter:EnumDisplayNameConverter x:Key="EnumDisplayNameConverter" />
		<converter:CountToIsVisibleConverter x:Key="CountToIsVisibleConverter" />
	</UserControl.Resources>

	<Border Name="ToolBarBorder" 
	        BorderBrush="Gray" 
	        BorderThickness="1" 
	        Margin="1"
	        IsVisible="{Binding ToolbarMenuItems.Count, Converter={StaticResource CountToIsVisibleConverter}}">
		
		<ItemsControl ItemsSource="{Binding ToolbarMenuItems}">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<StackPanel Orientation="Horizontal" Spacing="0" />
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
			
			<ItemsControl.ItemTemplate>
				<DataTemplate DataType="vmMap:PageToolBarButtonInfo">
					<Button Command="{Binding $parent[ItemsControl].DataContext.ToolbarCommand}"
					        CommandParameter="{Binding ButtonID}"
					        Margin="5"
					        HorizontalAlignment="Stretch"
					        Padding="10">

						<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
							<TextBlock Text="{Binding ButtonName}" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>
	</Border>

</UserControl>