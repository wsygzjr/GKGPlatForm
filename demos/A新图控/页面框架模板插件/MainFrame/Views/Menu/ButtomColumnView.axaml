<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MainFrame.ViewModels;assembly=MainFrame"
             xmlns:converter="clr-namespace:MainFrame.Converter"
             x:Class="MainFrameView.Views.Menu.ButtomColumnView"
             mc:Ignorable="d"
             x:DataType="vm:ButtomColumnViewModel"
             d:DesignWidth="800" d:DesignHeight="60">
	<Design.DataContext>
		<vm:ButtomColumnViewModel />
	</Design.DataContext>
	<!-- 引入转换器 -->
	<UserControl.Resources>
	</UserControl.Resources>
	<UserControl.Styles>
	</UserControl.Styles>
	<DockPanel HorizontalAlignment="Stretch" LastChildFill="True" Height="80">
		<ContentControl
		Content="{Binding CurrentContent}"
		HorizontalAlignment="Stretch"
		VerticalContentAlignment="{Binding VerticalContentAlignment}"
		HorizontalContentAlignment="{Binding HorizontalContentAlignment}"
		/>
	</DockPanel>
</UserControl>
