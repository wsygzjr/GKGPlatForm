<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="200"
             x:Class="Griffins.Map.PressureFuncCtlMapCell.View.PressureHView">
    <Border x:Name="MainBorder" BorderBrush="DarkRed" BorderThickness="2">
        <Grid RowDefinitions="*,2*">
            <Border Background="Green" Grid.Row="0">
                <Image Source="avares://Griffins.Map.PressureFuncCtlMapCell/Assets/Images/Pressure.png"
                       Stretch="None"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center">
                </Image>
            </Border>
            <Grid Grid.Row="1" RowDefinitions="1.5*,2*">
                <TextBlock Text="供阀气压" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Row="0">
                </TextBlock>
                <TextBlock x:Name="PressureValue" Text="" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Row="1">
                </TextBlock>
            </Grid>
        </Grid>
    </Border>
</UserControl>
