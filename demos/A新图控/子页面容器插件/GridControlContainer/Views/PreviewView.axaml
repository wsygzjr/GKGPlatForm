<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
			 xmlns:vm="using:GKG.Map.Page.UIContainer.GridContainer.ViewModels"
			 xmlns:view="using:GKG.Map.Page.UIContainer.GridContainer.Views"
             x:Class="GKG.Map.Page.UIContainer.GridContainer.Views.PreviewView"
             x:DataType="vm:PreviewViewModel" >
	<Design.DataContext>
		<vm:PreviewViewModel />
	</Design.DataContext>
	
	<UserControl.Styles>
		<FluentTheme />
		<StyleInclude Source="avares://GridControlContainer/Assets/TabControlStyles.axaml" />
	</UserControl.Styles>

	<view:WorkAreaView DataContext="{Binding WorkAreaViewModel}"  Grid.Row="1" />
</UserControl>
