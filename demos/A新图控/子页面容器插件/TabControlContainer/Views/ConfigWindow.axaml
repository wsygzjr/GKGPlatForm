<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:GKG.Map.Page.UIContainer.TabControlContainer.ViewModels"
		xmlns:customMenuCmdConfig="using:Griffins.Map.UI.CustomMenuCmdConfig"
		mc:Ignorable="d"
        x:Class="GKG.Map.Page.UIContainer.TabControlContainer.Views.ConfigWindow"
        x:DataType="vm:ConfigViewModel"
        Title="插件配置" Width="800" Height="600"
		WindowStartupLocation="CenterScreen" >
	<Design.DataContext>
		<vm:ConfigViewModel />
	</Design.DataContext>

	<Grid Margin="10">
		<!-- Tab控件 -->
		<TabControl >
			<!-- 工作区配置 -->
			<TabItem  Header="工作区配置">
				<customMenuCmdConfig:WorkAreaConfigView DataContext="{Binding WorkAreaConfigVM}" />
			</TabItem>
		
		</TabControl>

		<!-- 底部按钮区域 -->
		<StackPanel
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Spacing="10"
            Margin="0,10,0,0"
            VerticalAlignment="Bottom">
			<Button Content="关闭" Command="{Binding CloseCommand}" Width="80"/>
		</StackPanel>
	</Grid>
</Window>
