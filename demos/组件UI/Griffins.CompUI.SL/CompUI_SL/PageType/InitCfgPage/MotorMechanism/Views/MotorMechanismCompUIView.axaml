<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="clr-namespace:Griffins.CompUI.SL.InitCfgPage.ViewModels"
			 mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
			 xmlns:conv="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base"
			 x:DataType="vm:MotorMechanismCompUIViewModel"
			 xmlns:custom="clr-namespace:GKG.UI;assembly=GKG.UI"
			 xmlns:gkgUI="clr-namespace:GKG.UI.General;assembly=GKG.UI"
			 x:Class="Griffins.CompUI.SL.InitCfgPage.Views.MotorMechanismCompUIView"
			 Tag="{Binding ViewTag, Mode=TwoWay}">

	<gkgUI:MotorLinearMotionMechanismView DataContext="{Binding MotorLinearMotionMechanismViewModel}"/>
</UserControl>