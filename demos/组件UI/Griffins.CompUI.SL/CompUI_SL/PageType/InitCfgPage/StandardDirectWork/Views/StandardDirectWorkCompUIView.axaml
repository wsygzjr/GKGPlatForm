<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="clr-namespace:Griffins.CompUI.SL.InitCfgPage.ViewModels"
			 xmlns:gkgUI="clr-namespace:GKG.UI.General;assembly=GKG.UI"
			 xmlns:custom="clr-namespace:GKG.UI;assembly=GKG.UI"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:DataType="vm:StandardDirectWorkCompUIViewModel"
			 x:Class="Griffins.CompUI.SL.InitCfgPage.Views.StandardDirectWorkCompUIView"
			 Tag="{Binding ViewTag, Mode=TwoWay}">
	<Design.DataContext>
		<vm:StandardDirectWorkCompUIViewModel />
	</Design.DataContext>

	<Grid Margin="10" RowDefinitions="Auto,*" ColumnDefinitions="*" x:Name="Root">

		<!-- 顶部：改为 Grid 三列，让每个“模块卡片”顶对齐，并统一宽度/内边距 -->
		<Grid Grid.Row="0"
			  ColumnDefinitions="*,*,*"
			  ColumnSpacing="16">

			<!-- 扫码器 -->
			<Border Grid.Column="0" Padding="10" BorderBrush="#D9D9D9" BorderThickness="1" CornerRadius="6">
				<StackPanel Orientation="Vertical" Spacing="8" VerticalAlignment="Top">
					<TextBlock Text="扫码器" FontWeight="Bold" FontSize="16" Margin="0,0,0,6" />

					<custom:ToggleSwitchControl
					LabelName="是否启用"
					WidthLevel="Medium3"
					ViewModel="{Binding ScannerEnabledViewModel}" />

					<custom:TextInputControl
					LabelName="条码检验字符"
					WidthLevel="Medium3"
					ViewModel="{Binding BarcodeCheckCharViewModel}" />

					<custom:ComboxControl
					LabelName="条码类型"
					WidthLevel="Medium3"
					ViewModel="{Binding BarcodeTypeViewModel}" />

					<custom:TextInputControl
					LabelName="扫码器类型"
					WidthLevel="Medium3"
					ViewModel="{Binding ScannerTypeViewModel}" />
				</StackPanel>
			</Border>

			<!-- 测高 + 顶升固定时间参数（同列上下排，内部也做“卡片分组”） -->
			<Border Grid.Column="1" Padding="10" BorderBrush="#D9D9D9" BorderThickness="1" CornerRadius="6">
				<StackPanel Orientation="Vertical" Spacing="12" VerticalAlignment="Top">

					<!-- 测高 -->
					<StackPanel Orientation="Vertical" Spacing="8">
						<TextBlock Text="测高" FontWeight="Bold" FontSize="16" Margin="0,0,0,6" />
						<custom:NumericWithLableControl
						LabelName="测高延时"
						WidthLevel="Medium3"
						ViewModel="{Binding HeightDelayMsViewModel}" />
					</StackPanel>

					<!-- 分隔线（避免三块高度差太大时视觉散乱） -->
					<Border Height="1" Background="#EEEEEE" Margin="0,2" />

					<!-- 顶升固定时间参数 -->
					<StackPanel Orientation="Vertical" Spacing="8">
						<TextBlock Text="顶升固定时间参数" FontWeight="Bold" FontSize="16" Margin="0,0,0,6" />
						<custom:NumericWithLableControl
						LabelName="固定时间"
						WidthLevel="Medium3"
						ViewModel="{Binding LiftFixedTimeMsViewModel}" />
						<custom:NumericWithLableControl
						LabelName="解除固定时间"
						WidthLevel="Medium3"
						ViewModel="{Binding LiftReleaseFixedTimeMsViewModel}" />
					</StackPanel>

				</StackPanel>
			</Border>

			<!-- 温度控制 -->
			<Border Grid.Column="2" Padding="10" BorderBrush="#D9D9D9" BorderThickness="1" CornerRadius="6">
				<StackPanel Orientation="Vertical" Spacing="8" VerticalAlignment="Top">
					<TextBlock Text="温度控制" FontWeight="Bold" FontSize="16" Margin="0,0,0,6" />

					<custom:ToggleSwitchControl
					LabelName="是否检测开启"
					WidthLevel="Medium3"
					ViewModel="{Binding TempDetectEnabledViewModel}" />

					<custom:ToggleSwitchControl
					LabelName="是否工作开启"
					WidthLevel="Medium3"
					ViewModel="{Binding TempWorkEnabledViewModel}" />

					<custom:ToggleSwitchControl
					LabelName="是否预加热"
					WidthLevel="Medium3"
					ViewModel="{Binding TempPreheatEnabledViewModel}" />
				</StackPanel>
			</Border>

		</Grid>

		<!-- 底部：工位自定义感应器列表 -->
		<Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,12,0,0">

			<Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
				<TextBlock Grid.Column="0" Text="工位自定义感应器列表" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
				<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
					<Button Content="添加" Command="{Binding AddCommand}" />
					<Button Content="删除" Command="{Binding DeleteCommand}" />
				</StackPanel>
			</Grid>

			<DataGrid Grid.Row="1"
					  ItemsSource="{Binding CustomStationSensors}"
					  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
					  AutoGenerateColumns="False"
					  BorderBrush="LightGray"
					  BorderThickness="1"
					  IsReadOnly="False"
					  SelectionMode="Single"
					  RowHeight="40"
					  VerticalAlignment="Stretch"
					  HorizontalAlignment="Stretch"
					  CanUserSortColumns="False"
					  Margin="0,0,0,6" Classes="StyleDataGrid">
				<DataGrid.Columns>
					<DataGridTemplateColumn Width="70">
						<DataGridTemplateColumn.HeaderTemplate>
							<DataTemplate>
								<CheckBox IsChecked="{Binding DataContext.IsSelectAll, Mode=TwoWay, ElementName=Root}"
										  HorizontalAlignment="Center"
										  VerticalAlignment="Center" />
							</DataTemplate>
						</DataGridTemplateColumn.HeaderTemplate>
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate>
								<CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
										  HorizontalAlignment="Center"
										  VerticalAlignment="Center" />
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

					<DataGridTextColumn Header="序号" Binding="{Binding Index}" Width="68" IsReadOnly="True" />

					<!-- 感应器ID：NumericUpDown -> TextBox -->
					<DataGridTemplateColumn Header="感应器ID" Width="150">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate>
								<TextBox Text="{Binding SensorId, Mode=TwoWay}"
										 HorizontalAlignment="Stretch"
										 MinWidth="130" />
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

					<!-- 运控卡ID：NumericUpDown -> TextBox -->
					<DataGridTemplateColumn Header="运控卡ID" Width="150">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate>
								<TextBox Text="{Binding MotionCardId, Mode=TwoWay}"
										 HorizontalAlignment="Stretch"
										 MinWidth="130" />
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>

					<!-- IO通道：NumericUpDown -> TextBox -->
					<DataGridTemplateColumn Header="IO通道" Width="150">
						<DataGridTemplateColumn.CellTemplate>
							<DataTemplate>
								<TextBox Text="{Binding IoChannel, Mode=TwoWay}"
										 HorizontalAlignment="Stretch"
										 MinWidth="130" />
							</DataTemplate>
						</DataGridTemplateColumn.CellTemplate>
					</DataGridTemplateColumn>
				</DataGrid.Columns>
			</DataGrid>

		</Grid>

	</Grid>

</UserControl>