<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="clr-namespace:Griffins.CompUI.SL.InitCfgPage.ViewModels"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="Griffins.CompUI.SL.InitCfgPage.Views.TrackBasicParamCompUIView"
			 xmlns:custom="clr-namespace:GKG.UI;assembly=GKG.UI"
			 x:DataType="vm:TrackBasicParamCompUIViewModel"
			 Tag="{Binding ViewTag, Mode=TwoWay}">
	<Design.DataContext>
		<vm:TransportMotorCompUIViewModel/>
	</Design.DataContext>
	<StackPanel Orientation="Vertical" Spacing="20" Margin="0 30 0 0">

		<StackPanel Orientation="Horizontal" Spacing="12">
			<custom:ToggleSwitchControl WidthLevel="Medium2"
										LabelName="回流不回板"
										ViewModel="{Binding RefluxNoBoardViewModel}"/>
		</StackPanel>

		<StackPanel Orientation="Horizontal" Spacing="12">
			<custom:ToggleSwitchControl WidthLevel="Medium2"
										LabelName="是否下位机要板优先"
										ViewModel="{Binding SlavePriorityViewModel}"/>
		</StackPanel>

	</StackPanel>
</UserControl>