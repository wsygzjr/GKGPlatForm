<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:ui="using:GKG.UI"
			 xmlns:views="clr-namespace:GKG.UI.General"
			 xmlns:local="using:GKG.UI.General"
			 xmlns:vision="using:AvaloniaVisionControl"
			 xmlns:vm="clr-namespace:GKG.UI.General"
			 x:DataType="vm:ExternalScannerViewModel"
			 xmlns:custom="clr-namespace:GKG.UI;assembly=GKG.UI"
			 x:Class="GKG.UI.General.ExternalScannerView">

	<!-- 外接扫码器参数配置界面View -->
	<Grid Margin="5 0 5 0" HorizontalAlignment="Stretch" VerticalAlignment="Top" RowDefinitions="auto,auto,auto,auto,auto">
		<!-- 标题 -->
		<Label Grid.Row="0" Content="外接扫码器参数配置界面" FontSize="20" HorizontalAlignment="Left" Margin="0 0 0 10" />

		<!-- 开关：是否启用 -->
		<custom:ToggleSwitchControl
		Grid.Row="1"
		HorizontalAlignment="Center"
		HorizontalContentAlignment="Center"
		VerticalContentAlignment="Center"
		LabelName="是否启用:"
		WidthLevel="Medium3"
		ViewModel="{Binding EnableViewModel}" />

		<!-- 文本输入：条码校验字符串 -->
		<custom:TextInputControl
		Grid.Row="2"
		HorizontalAlignment="Center"
		HorizontalContentAlignment="Center"
		VerticalContentAlignment="Center"
		LabelName="条码校验字符串:"
		WidthLevel="Medium3"
		ViewModel="{Binding BarcodeValidationStringViewModel}" />

		<!-- 下拉框：条码类型 -->
		<custom:ComboxControl
		Grid.Row="3"
		HorizontalAlignment="Center"
		HorizontalContentAlignment="Center"
		VerticalContentAlignment="Center"
		LabelName="条码类型:"
		WidthLevel="Medium3"
		ViewModel="{Binding BarcodeTypeViewModel}" />

		<!-- 文本输入：扫码器类型 -->
		<custom:TextInputControl
		Grid.Row="4"
		HorizontalAlignment="Center"
		HorizontalContentAlignment="Center"
		VerticalContentAlignment="Center"
		LabelName="扫码器类型:"
		WidthLevel="Medium3"
		ViewModel="{Binding ScannerTypeViewModel}" />
	</Grid>

</UserControl>