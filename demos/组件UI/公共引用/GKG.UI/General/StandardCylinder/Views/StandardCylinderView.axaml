<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             xmlns:vm="clr-namespace:GKG.UI.General"
             xmlns:custom="clr-namespace:GKG.UI;assembly=GKG.UI"
             xmlns:gkgUI="clr-namespace:GKG.UI.General;assembly=GKG.UI"
             x:DataType="vm:StandardCylinderViewModel"
             x:Class="GKG.UI.General.StandardCylinderView">
    <UserControl.DataTemplates>
        <DataTemplate DataType="vm:SingleControlSingleLimitViewModel">
            <gkgUI:SingleControlSingleLimitView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="vm:SingleControlDoubleLimitViewModel">
            <gkgUI:SingleControlDoubleLimitView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="vm:DoubleControlSingleLimitViewModel">
            <gkgUI:DoubleControlSingleLimitView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="vm:DoubleControlDoubleLimitViewModel">
            <gkgUI:DoubleControlDoubleLimitView DataContext="{Binding}"/>
        </DataTemplate>
    </UserControl.DataTemplates>

    <Grid RowDefinitions="auto,*" Margin="5 0 5 0" HorizontalAlignment="Stretch" VerticalAlignment="Top">
        <custom:ComboxControl
            Grid.Row="0"
            LabelName="气缸类型"
            WidthLevel="Medium3"
            ViewModel="{Binding ModeSelectorViewModel}"
            />

        <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="10" Margin="0 10 0 0">
            <gkgUI:CylinderPageTypeRowView DataContext="{Binding PageTypeRowViewModel}"/>
            <ContentControl Content="{Binding CurrentContentViewModel}"/>
        </StackPanel>
    </Grid>
</UserControl>
