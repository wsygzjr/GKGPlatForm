<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="clr-namespace:GKG.UI.General"
             xmlns:custom="clr-namespace:GKG.UI;assembly=GKG.UI"
             xmlns:gkgUI="clr-namespace:GKG.UI.General;assembly=GKG.UI"
             x:DataType="vm:SingleControlSingleLimitViewModel"
             x:Class="GKG.UI.General.SingleControlSingleLimitView">
    <StackPanel Orientation="Vertical" Spacing="10" HorizontalAlignment="Left" VerticalAlignment="Top">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="控制" FontSize="18" Background="Transparent" Foreground="Gray" Margin="2 15 0 0"/>
            <gkgUI:HorizontalControlCardStateInitView DataContext="{Binding ControlViewModel}"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="限位" FontSize="18" Background="Transparent" Foreground="Gray" Margin="2 15 0 0"/>
            <gkgUI:HorizontalControlCardStateInitView DataContext="{Binding LimitViewModel}"/>
        </StackPanel>

        <gkgUI:CylinderDelayView DataContext="{Binding CylinderDelayViewModel}"/>
    </StackPanel>
</UserControl>
