<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
    <Border Padding="20">
      <!-- Add Controls for Previewer Here -->
    </Border>
  </Design.PreviewWith>

  <!-- Add Styles Here   -->
      <!-- border样式-->  
    <Style Selector="Border.borderName"> 
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="BorderThickness" Value="1"/> 
        <Setter Property="CornerRadius" Value="4"/> 
        <Setter Property="Background" Value="White"/>   
        <Setter Property="Margin" Value="4,2"/>  
        <Setter Property="Cursor" Value="Hand"/>   
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>  

     <!-- Label样式  -->
    <Style Selector="Grid TextBlock.textBlock">
        <Setter Property="HorizontalAlignment"  Value="Left"/>
        <Setter Property="TextAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>   
        <Setter Property="Margin" Value="0,5,0,0"/>
        <Setter Property="Padding" Value="0"/> 
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="FontFamily" Value="SimSun"/>   
    </Style> 

   <!-- ContentControl样式 -->
    <Style Selector="Panel.contentControl"> 
        <Setter Property="VerticalAlignment" Value="Center"/> 
        <Setter Property="Background" Value="Transparent"/>  
        <Setter Property="Margin" Value="0,0"/>  
    </Style> 

     <!-- Lable框样式 -->
    <Style Selector="TextBlock#TextBlock1"> 
        <Setter Property="Height" Value="35"/> 
        <Setter Property="Margin" Value="8 4"/>   
        <Setter Property="Background" Value="#CCCCCC"/> 
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Padding" Value="8 4"/>
        <Setter Property="FontSize" Value="14"/>  
        <Setter Property="FontFamily" Value="NSimSun"/> 
    </Style>  
     
    <!-- 文本框样式 -->
    <Style Selector="TextBox#TextBox1">
        <Setter Property="Height" Value="35"/>
        <Setter Property="Margin" Value="8 4"/>  
        <Setter Property="Padding" Value="8 4"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/> 
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontSize" Value="14"/>  
        <Setter Property="FontFamily" Value="NSimSun"/> 
    </Style>    
 
  <!-- 日历日期选择器样式 -->
    <Style Selector="CalendarDatePicker#CalendarDatePicker1">
        <Setter Property="Height" Value="35"/>
        <Setter Property="Margin" Value="8 4"/>  
        <Setter Property="Padding" Value="8 4"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/> 
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontSize" Value="14"/>  
        <Setter Property="FontFamily" Value="NSimSun"/> <!-- 宋体 -->  
        <Setter Property="HorizontalContentAlignment" Value="Center"/> 
        <Setter Property="VerticalContentAlignment" Value="Center"/>  
        <Setter Property="HorizontalAlignment" Value="Center"/> 
        <Setter Property="VerticalAlignment" Value="Center"/>    
    </Style> 

    
   <!-- 时间选择器样式 -->
    <Style Selector="TimePicker#TimePicker1">
        <Setter Property="Height" Value="35"/>
        <Setter Property="Margin" Value="8 4"/>  
        <Setter Property="Padding" Value="8 4"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/> 
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontSize" Value="14"/>  
        <Setter Property="FontFamily" Value="NSimSun"/> <!-- 宋体 -->  
        <Setter Property="HorizontalAlignment" Value="Center"/> 
        <Setter Property="VerticalAlignment" Value="Center"/>   
    </Style>   
    
       <!--开关按钮样式--> 
    <Style Selector="ToggleSwitch#InnerToggle"> 
        <Setter Property="Height" Value="35"/>
        <Setter Property="Margin" Value="8 4"/>  
        <Setter Property="Padding" Value="8 4"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/> 
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontSize" Value="14"/>  
        <Setter Property="FontFamily" Value="NSimSun"/>  
        <Setter Property="HorizontalContentAlignment" Value="Left"/>  
        <Setter Property="VerticalContentAlignment" Value="Center"/>  
        <Setter Property="HorizontalAlignment" Value="Center"/> 
        <Setter Property="VerticalAlignment" Value="Center"/>     
    </Style> 
    
       <!-- 数字输入框样式 -->
    <Style Selector="NumericUpDown#NumericUpDown1"> 
        <Setter Property="Height" Value="35"/>
        <Setter Property="Margin" Value="8 4"/>  
        <Setter Property="Padding" Value="8 4"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/> 
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontSize" Value="14"/>  
        <Setter Property="FontFamily" Value="NSimSun"/> <!-- 宋体 -->  
        <Setter Property="HorizontalContentAlignment" Value="Center"/> 
        <Setter Property="VerticalContentAlignment" Value="Center"/>  
    </Style>  

         <!--下拉框样式--> 
    <Style Selector="ComboBox#ComboBox1"> 
       <Setter Property="Height" Value="35"/>
       <Setter Property="Margin" Value="8 4"/>  
       <Setter Property="Padding" Value="4 2"/> 
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/> 
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontSize" Value="14"/>  
        <Setter Property="FontFamily" Value="NSimSun"/> <!-- 宋体 -->    
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>

    <Style Selector="ComboBox#ComboBox1 TextBlock">
        <Setter Property="TextTrimming" Value="None"/>
    </Style>

       <!--下拉框pannel的样式--> 
    <Style Selector="StackPanel#stackPanel1"> 
     <!--   <Setter Property="Height" Value="35"/>-->
        <Setter Property="Margin" Value="8 0 8 0"/>     
     <!--   <Setter Property="Background" Value="#CCCCCC"/>  -->
    </Style>  

       <!--单位框pannel的样式--> 
    <Style Selector="StackPanel#stackPanel2"> 
     <!--   <Setter Property="Height" Value="35"/>-->
        <Setter Property="Margin" Value="0 0 0 0"/>       
        <!--<Setter Property="Background" Value="#CCCCCC"/>-->  
    </Style> 
      <!-- 可编辑文本框框样式 -->
     <Style Selector="TextBox#InputTextBox"> 
        <Setter Property="Height" Value="25"/>
        <Setter Property="Margin" Value="0,2.0,0,6.0"/>  <!-- 左上右下 --> 
        <Setter Property="Padding" Value="8 4 0 4"/>
        <Setter Property="BorderThickness" Value="0"/> 
        <Setter Property="FontSize" Value="14"/>  
        <Setter Property="FontFamily" Value="NSimSun"/>   
        <Setter Property="VerticalContentAlignment" Value="Center"/>  
        <Setter Property="HorizontalAlignment" Value="Center"/> 
        <Setter Property="VerticalAlignment" Value="Center"/>     
     </Style>
      <!-- 自定义 TextBox 的 Watermark 颜色 -->
        <Style Selector="TextBox#InputTextBox > TextBlock#PART_Watermark">
            <!-- 调亮颜色：使用浅色值（如 #888888、#AAAAAA，越接近白色越亮） -->
            <Setter Property="Foreground" Value="#AAAAAA" />
            <!-- 可选：调整字体透明度（配合颜色调亮） -->
            <!-- <Setter Property="Opacity" Value="0.8" /> -->
        </Style>
 
         <!-- 可编辑下拉框样式 --> 
     <Style Selector="ComboBox#InnerComboBox">  
        <Setter Property="Height" Value="35"/>
        <Setter Property="Margin" Value="0,0.5,0,2.0"/>  <!-- 左上右下 --> 
        <Setter Property="Padding" Value="8 4 0 4"/>
        <Setter Property="BorderThickness" Value="1.5"/>    
        <Setter Property="BorderBrush" Value="#CCCCCC"/> 
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontSize" Value="14"/>  
        <Setter Property="FontFamily" Value="NSimSun"/>   
     </Style>  
      <!--下拉框选中后显示区域的文字透明 --> 
    <Style Selector="ComboBox#InnerComboBox ContentPresenter">
        <Setter Property="Foreground" Value="Transparent"/>
    </Style>  
     
       <!--  begin滑块样式 -->
    <Style Selector="Slider#InnerSlider"> 
        <Setter Property="Height" Value="35"/>
        <Setter Property="Margin" Value="0 0 0 0"/> 
        <Setter Property="Padding" Value="0 0 0 10"/>  
        <Setter Property="HorizontalAlignment" Value="Center"/> 
        <Setter Property="VerticalAlignment" Value="Center"/>   
    </Style>
       <!-- 数字输入框样式 -->
    <Style Selector="NumericUpDown#SliderNumericControlInnerNumericUpDown"> 
        <Setter Property="Height" Value="35"/>
        <Setter Property="Margin" Value="6 1 0 0"/>  
        <Setter Property="Padding" Value="0 4 0 4"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/> 
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontSize" Value="14"/>  
        <Setter Property="FontFamily" Value="NSimSun"/>   
        <Setter Property="HorizontalContentAlignment" Value="Center"/> 
        <Setter Property="VerticalContentAlignment" Value="Center"/>  
    </Style> 
     <!--  end滑段样式 -->

       <!--  begin 数值+单位 样式 -->
          <!-- 数字输入框样式 -->
    <Style Selector="NumericUpDown#NumericWithLableControlInnerNumericUpDown1"> 
        <Setter Property="Height" Value="35"/> 
        <Setter Property="Margin" Value="0 4"/>  
        <Setter Property="Padding" Value="0 4"/> 
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/> 
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontSize" Value="14"/>  
        <Setter Property="FontFamily" Value="NSimSun"/>   
        <Setter Property="HorizontalContentAlignment" Value="Center"/> 
        <Setter Property="VerticalContentAlignment" Value="Center"/>  
        <Setter Property="HorizontalAlignment" Value="Left"/> 
        <Setter Property="VerticalAlignment" Value="Center"/>  
    </Style> 

          <!-- 单位Label样式  -->
    <Style Selector="TextBlock#InnerTextBlock1">
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="TextAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Center"/>  
       <!-- <Setter Property="Margin" Value="6 1 0 0"/>  -->
        <Setter Property="Margin" Value="0 1 0 0"/>  
        <Setter Property="Padding" Value="6 4 0 4"/>
        <Setter Property="Height" Value="35"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Foreground" Value="#333333"/> 
        <Setter Property="FontFamily" Value="SimSun"/>   
    </Style> 
    <!--  end 数值+单位 样式 -->
       
</Styles>
 