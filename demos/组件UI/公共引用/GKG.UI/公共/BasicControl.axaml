<ReactiveUserControl 
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:rxui="clr-namespace:ReactiveUI.Avalonia;assembly=ReactiveUI.Avalonia"
    x:Class="GKG.UI.BasicControlLayout"
    MinHeight="40" 
    >
    <ReactiveUserControl.Styles>
        <FluentTheme />   
         <StyleInclude Source="avares://GKG.UI/Styles/Styles.axaml" />  
    </ReactiveUserControl.Styles>   
     
       
<Border   x:Name="borderName"  Classes="borderName" > 

     <Grid ColumnDefinitions="Auto,*"  x:Name="MainGrid"  >   
          <TextBlock 
                Classes="textBlock"
                x:Name="labelText" 
                Grid.Column="0"
                VerticalAlignment="Center" /> 

            <Panel  
                Classes="contentControl"
                x:Name="contentControl" 
                Grid.Column="1" 
                HorizontalAlignment="Stretch"/>
     </Grid>
		
	</Border>


</ReactiveUserControl>