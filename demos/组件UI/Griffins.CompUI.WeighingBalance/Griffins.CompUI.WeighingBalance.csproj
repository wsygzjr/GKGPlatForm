<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Company>Griffins</Company>
    <Copyright>Copyright © Griffins 2026</Copyright>
    <AssemblyVersion>7.1.0.0</AssemblyVersion>
    <FileVersion>7.1.0.0</FileVersion>
    <AssemblyTitle>Griffins.CompUI.WeighingBalance</AssemblyTitle>
    <Product>Griffins.CompUI.WeighingBalance</Product>
	  <TargetFramework>net9.0</TargetFramework>
	  <OutputType>Library</OutputType>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <OutputPath>F:\Griffins7.1\Bin\Share\CompUI\</OutputPath>
   
  </PropertyGroup>

  <ItemGroup>
    <AvaloniaXaml Update="**\*.axaml">
      <Generator>MSBuild:Compile</Generator>
    </AvaloniaXaml>
  </ItemGroup>

  <ItemGroup>
	  <PackageReference Include="Griffins.ImeIOT" Version="7.1.0">
		  <ExcludeAssets>runtime</ExcludeAssets>
	  </PackageReference>
	  <PackageReference Include="Griffins.UI2" Version="7.1.0">
		  <ExcludeAssets>runtime</ExcludeAssets>
	  </PackageReference>
	  <PackageReference Include="Griffins.Map2" Version="7.1.0">
		  <ExcludeAssets>runtime</ExcludeAssets>
	  </PackageReference>
	  <PackageReference Include="Griffins.ImeIOT.Map" Version="7.1.0">
		  <ExcludeAssets>runtime</ExcludeAssets>
	  </PackageReference>
	  <PackageReference Include="Griffins.Map.UI" Version="7.1.0">
		  <ExcludeAssets>runtime</ExcludeAssets>
	  </PackageReference>
    
    <PackageReference Include="Microsoft.CSharp" Version="4.7.0">
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
    <PackageReference Include="Newtonsoft.JsonG" Version="7.1.0">
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
    <PackageReference Include="Avalonia" Version="11.3.3">
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
    <PackageReference Include="Avalonia.ReactiveUI" Version="11.3.3">
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
    <PackageReference Include="RJCP.SerialPortStream" Version="3.0.4" />
    <PackageReference Include="GKG.ElectronicControl" Version="1.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="F:\demos\组件UI\公共引用\GKG\GKG.csproj">
      <Private>False</Private>
      <ExcludeAssets>runtime</ExcludeAssets>
    </ProjectReference>
    <ProjectReference Include="F:\demos\组件UI\公共引用\GKG.UI\GKG.UI.csproj">
      <Private>False</Private>
      <ExcludeAssets>runtime</ExcludeAssets>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <Reference Include="WeighingBalanceSubMachineModules">
      <HintPath>F:\Griffins7.1\Bin\Share\ImeIOT\SubMM\WeighingBalanceSubMachineModules.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Compile Update="CompUI_WeighingBalance\PageType\InitCfgPage\WeighingBalance\Views\WeighingBalanceInitCfgCompUIView.axaml.cs">
      <DependentUpon>WeighingBalanceInitCfgCompUIView.axaml</DependentUpon>
    </Compile>
  </ItemGroup>

	<!-- 自定义目标：清理输出 -->
	 
	<Target Name="CleanOutputDependencies" AfterTargets="Build">
		 
		<ItemGroup>

			<!-- 要删除的 DLL 文件 -->

			<DllsToDelete Include="$(OutputPath)GKG.dll" />
			<DllsToDelete Include="$(OutputPath)GKG.UI.dll" />
			<DllsToDelete Include="$(OutputPath)AvaloniaVisionControl.dll" />
			<DllsToDelete Include="$(OutputPath)BasicRobotSubMachineModules.dll" />
			<DllsToDelete Include="$(OutputPath)CategoryARobotSubMachineModules.dll" />
			<DllsToDelete Include="$(OutputPath)DispensingFunctionHeadSubMachineModules.dll" />
			<DllsToDelete Include="$(OutputPath)GKG.ElectronicControl.dll" />
			<DllsToDelete Include="$(OutputPath)GKG.MotionControl.dll" />
			<DllsToDelete Include="$(OutputPath)PokaYoke.dll" />
			<DllsToDelete Include="$(OutputPath)WeighingBalanceSubMachineModules.dll" />
			<DllsToDelete Include="$(OutputPath)Valve.dll" />


			<!-- 要删除的 PDB 文件 -->

			<DllsToDelete Include="$(OutputPath)GKG.pdb" />
			<PdbsToDelete Include="$(OutputPath)GKG.UI.pdb" />
			<PdbsToDelete Include="$(OutputPath)AvaloniaVisionControl.pdb" />
			<DllsToDelete Include="$(OutputPath)BasicRobotSubMachineModules.pdb" />
			<PdbsToDelete Include="$(OutputPath)CategoryARobotSubMachineModules.pdb" />
			<PdbsToDelete Include="$(OutputPath)DispensingFunctionHeadSubMachineModules.pdb" />
			<DllsToDelete Include="$(OutputPath)GKG.ElectronicControl.pdb" />
			<PdbsToDelete Include="$(OutputPath)GKG.MotionControl.pdb" />
			<PdbsToDelete Include="$(OutputPath)PokaYoke.pdb" />
			<PdbsToDelete Include="$(OutputPath)Valve.pdb" />
			<PdbsToDelete Include="$(OutputPath)WeighingBalanceSubMachineModules.pdb" />
			 
			
			 
			<!-- 要删除的 XML 文件 -->
			 
			<DllsToDelete Include="$(OutputPath)GKG.xml" /> 
			<XmlsToDelete Include="$(OutputPath)GKG.UI.xml" />
			<XmlsToDelete Include="$(OutputPath)AvaloniaVisionControl.xml" />
			 
			
		
			<!-- 合并所有要删除的文件 -->
			
			<AllFilesToDelete Include="@(DllsToDelete)" />
			<AllFilesToDelete Include="@(PdbsToDelete)" />
			<AllFilesToDelete Include="@(XmlsToDelete)" />
		</ItemGroup>
		
		<!-- 删除文件 -->
		
		<Delete Files="@(AllFilesToDelete)" ContinueOnError="true" />
	</Target>
</Project>
