<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="clr-namespace:Griffins.CompUI.ElectricalMngObj.FactoryCfgPage.ViewModels.Axis"
             x:DataType="vm:PulseInputModeParamViewModel"
             x:Class="Griffins.CompUI.ElectricalMngObj.FactoryCfgPage.Views.PulseInputModeParamView" 
                 xmlns:custom="clr-namespace:Griffins.UI;assembly=Griffins.UI2"  >

	<!--<TextBlock Text="脉冲输入模式配置" VerticalAlignment="Top"/> 
-->
  <Grid Margin="0,0,0,0"
      RowDefinitions="*"  RowSpacing="0" ColumnSpacing="0"  >  <!-- 显式定义1行，自适应控件高度（可选但推荐） -->
    <!-- 单列布局：默认 Width="*"，可省略 ColumnDefinitions 简化代码 -->

        <!-- 脉冲输入模式 --> 
	    <custom:ComboxControl 
                     Grid.Row="0"  
                     HorizontalAlignment="Center"
                     HorizontalContentAlignment="Center"
                     VerticalAlignment="Center"
					LabelName="脉冲输入模式:"
					WidthLevel="Medium" 
					ViewModel="{Binding PulseInputModeModel}" />
              
    </Grid>

</UserControl>
