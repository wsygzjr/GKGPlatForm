<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="DispensingPageType.Views.RecipeParamCfgPage.ParametersAndCalculation.DispensingAfterPointStyleListView"

             xmlns:vm="clr-namespace:Griffins.CompUI.TestGlueDirectWorkMM.RecipeCfgPage.ViewModels.GlueDispensingStyle"
             xmlns:m ="clr-namespace:DispensingPageType.Models.RecipeParamCfgPage"
             xmlns:gkgUI="clr-namespace:Griffins.UI.General;assembly=PageTypeSimple"   
             x:DataType="vm:DispensingAfterPointStyleListViewModel"
             xmlns:custom="clr-namespace:Griffins.UI;assembly=Griffins.UI2"   
             xmlns:convert="clr-namespace:Griffins.CompUI.TestGlueDirectWorkMM.Converters" >
    
    <!-- 转换器 -->
    <UserControl.Resources>		
        <convert:ListCountToBoolConverter x:Key="ListCountToBoolConverter"/> 
        <convert:BoolToDisplayNameConverter x:Key="BoolToDisplayNameConverter"  /> <!-- 添加默认显示文本 --> 
    </UserControl.Resources>  

    <!--  点样式-点胶后  -->
    <DockPanel Margin="0" LastChildFill="True"  Width="1806" >  
        <!--1. 顶部操作菜单（添加按钮）--> 
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="1" Margin="1 0 0 1" Width="1706" > 
             <Button 
                Content="新增" 
                Command="{Binding AddCommand}" 
                Classes="DataGrid_btnAddStyle" Width="80"/>   
            <Button 
                Content="删除" 
                Command="{Binding BatchDeleteCommand}" 
                Classes="DataGrid_btnAddStyle" Width="80" 
                IsEnabled="{Binding CanBatchDelete}"/> <!-- 绑定批量删除可用状态 -->
        </StackPanel>

        <!-- DataGrid 配置  -->
       <DataGrid  Classes="StyleDataGrid"  VerticalAlignment="Top"
                ItemsSource="{Binding ItemsSource}"
                AutoGenerateColumns="False"
                BorderBrush="LightGray"
                BorderThickness="1"
                IsReadOnly="False" 
                SelectionMode="Extended"  
                RowHeight="40" 
                Width="1700"
                CanUserResizeColumns="True"
                CanUserSortColumns="True"
                Height="920"
         
            >  
      
            <DataGrid.Columns> 
                <!-- 全选列（不变） -->
                <DataGridTemplateColumn Width="130" IsReadOnly="True">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <CheckBox Classes="DataGrid_CheckBoxStyle"  
                                      IsChecked="{Binding DataContext.IsSelectAll, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                      Content="全选"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:DispensingAfterPointStyleCfgInfoModel">
                            <CheckBox Classes="DataGrid_CheckBoxStyle" 
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn> 

                <!-- 样式名称 -->
                <DataGridTemplateColumn    Header="样式名称"   Width="180"   > 
                     <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:DispensingAfterPointStyleCfgInfoModel">  
                            <TextBox Text="{Binding StyleNameViewModel.Text , Mode=TwoWay}"   Classes="DataGrid_TextBoxStyle"  
                                     Height="24"   Width="160"  /> 
                        </DataTemplate> 
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
             
                <!-- 稳定时间(ms) -->
                <DataGridTemplateColumn 
                    Header="稳定时间(ms)"   Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:DispensingAfterPointStyleCfgInfoModel">  
                             <NumericUpDown 
                                Value="{Binding StabilizationTimeViewModel.Value, Mode=TwoWay}"
                                Minimum="{Binding StabilizationTimeViewModel.Minimum}"
                                Increment="{Binding StabilizationTimeViewModel.Increment}"
                                 Width="160"  Classes="DataGrid_NumericUpDownStyle"   />  
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 回抬高度（mm）（修复单位） -->
                <DataGridTemplateColumn 
                    Header="回抬高度(mm)"   Width="180"
                   >
                    <DataGridTemplateColumn.CellTemplate  >
                        <DataTemplate DataType="vm:DispensingAfterPointStyleCfgInfoModel" >
                             <NumericUpDown 
                                Value="{Binding LiftHeightViewModel.Value, Mode=TwoWay}"
                                Minimum="{Binding LiftHeightViewModel.Minimum}"
                                Increment="{Binding LiftHeightViewModel.Increment}"
                                Classes="DataGrid_NumericUpDownStyle"   Width="160" />  
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>


                <!-- 提前开阀时间(ms) -->
                <DataGridTemplateColumn 
                    Header="回抬速度(mm/s)" 
                    Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:DispensingAfterPointStyleCfgInfoModel">
                            <NumericUpDown 
                                Value="{Binding LiftSpeedViewModel.Value, Mode=TwoWay}"
                                Minimum="{Binding LiftSpeedViewModel.Minimum}"
                                Increment="{Binding LiftSpeedViewModel.Increment}"
                                 Classes="DataGrid_NumericUpDownStyle"   Width="160"  />  
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                                        
                <!-- 操作列（删除按钮） -->
                <DataGridTemplateColumn 
                    Header="操作" 
                    Width="115" 
                    IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:DispensingAfterPointStyleCfgInfoModel">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="5 0">
                                <Button 
                                    Content="删除" 
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}" 
                                    Classes="DataGrid_btnDeleteStyle" >
                              <!--      <Button.IsEnabled>
                                        <MultiBinding Converter="{StaticResource ListCountToBoolConverter}">
                                            <Binding Path="DataContext.StyleList.Count" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                            <Binding Path="IsDummy" FallbackValue="False"/>
                                        </MultiBinding>
                                    </Button.IsEnabled>-->
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns> 
        </DataGrid>
    </DockPanel>  

</UserControl>