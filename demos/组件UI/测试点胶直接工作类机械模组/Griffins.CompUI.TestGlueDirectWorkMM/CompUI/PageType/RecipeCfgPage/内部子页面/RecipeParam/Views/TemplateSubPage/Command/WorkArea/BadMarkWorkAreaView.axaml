<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:ui="clr-namespace:Griffins.UI;assembly=Griffins.UI2"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="clr-namespace:Griffins.CompUI.TestGlueDirectWorkMM.RecipeCfgPage.ViewModels.TemplateSubPage.Command"
             xmlns:vm1="using:DispensingPageType.Models.RecipeParamCfgPage"
             xmlns:gkgUI="clr-namespace:Griffins.UI.General;assembly=PageTypeSimple"   
             xmlns:views="clr-namespace:DispensingPageType.Views.RecipeParamCfgPage.ParametersAndCalculation"
             x:DataType="vm:BadMarkWorkAreaViewModel"
             xmlns:custom="clr-namespace:Griffins.UI;assembly=Griffins.UI2"   
             xmlns:convert="clr-namespace:DispensingPageType.Converters" 
             x:Class="DispensingPageType.Views.RecipeParamCfgPage.ParametersAndCalculation.BadMarkWorkAreaView">
	
    
    <Border  Classes="border" >
        <StackPanel Orientation="Vertical"   Width="876"  Height="610" HorizontalAlignment="Left"  VerticalAlignment="Top"   >
             
			<TextBlock Text="BadMark设置"  Classes="TextBlockWorkAreaViewTitle" TextAlignment="Center" HorizontalAlignment="Center"  VerticalAlignment="Center" ></TextBlock> 

             <custom:ComboxControl 
		        HorizontalAlignment="Left"
		        HorizontalContentAlignment="Center"
		        VerticalAlignment="Center"
		        VerticalContentAlignment="Center"
		        LabelName="模式选择"
		        WidthLevel="Small"
		        ViewModel="{Binding ModelTypeViewModel  }" />  
                 
            <!--点胶头待机位置  视图模型GlueDspensingPositionViewModel --> 
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto"
                        RowSpacing="0"   Height="120" Width="876" HorizontalAlignment="Left" VerticalAlignment="Center"  > 
                              
                <TextBlock  Grid.Row="0"  Grid.Column="0"  HorizontalAlignment="Left"   VerticalAlignment="Top" 
                                FontFamily="SimSun"     FontSize="14"  Text="BadMark位置-记录位置" Margin="4,10,4,10"     />
                        
                <Grid   Grid.Row="1"  Grid.Column="0"  RowDefinitions="Auto,Auto" ColumnDefinitions="Auto"
                    RowSpacing="0"   Height="80" Width="580"  HorizontalAlignment="Left" VerticalAlignment="Center" > 
                      <!--  --><!-- 坐标表头 --><!--
                        <gkgUI:PositionTeachHeaderView    Grid.Row="0"  Grid.Column="0"  
                            Margin="0" Height="35" Width="580"  HorizontalAlignment="Left" VerticalAlignment="Center" />   
                        --><!-- 坐标数据 --><!--
                        <gkgUI:PositionTeachView    Grid.Row="1"  Grid.Column="0" 
                            DataContext="{Binding BadMarkPositionViewModel}" 
                            Margin="0" Height="50" Width="580"  HorizontalAlignment="Left" VerticalAlignment="Center" />   -->
                </Grid>
            </Grid> 
            
            <StackPanel Orientation="Horizontal"   >
                 <custom:ComboxControl 
		            HorizontalAlignment="Left"
		            HorizontalContentAlignment="Center"
		            VerticalAlignment="Center"
		            VerticalContentAlignment="Center"
		            LabelName="操作类型"
		            WidthLevel="Small"
		            ViewModel="{Binding OperationTypeViewModel  }" /> 

                 <Button 
                    Content="创建模板"   Classes="btnSave"
                    Command="{Binding CreateTemplateCommand}" 
                    Cursor="Hand"> 
                </Button> 

                 <Button 
                    Content="测试模板"   Classes="btnSave"
                    Command="{Binding TestTemplateCommand}" 
                    Cursor="Hand"> 
                </Button> 
            </StackPanel>
        </StackPanel>
      

    </Border>

    

</UserControl>
