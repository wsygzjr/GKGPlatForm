<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:ui="clr-namespace:Griffins.UI;assembly=Griffins.UI2"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="clr-namespace:Griffins.CompUI.TestGlueDirectWorkMM.RecipeCfgPage.ViewModels.TemplateSubPage.TrajectorySequence"
             xmlns:vm1="using:DispensingPageType.Models.RecipeParamCfgPage"
             xmlns:gkgUI="clr-namespace:Griffins.UI.General;assembly=PageTypeSimple"   
                xmlns:custom="clr-namespace:Griffins.UI;assembly=Griffins.UI2"   
             xmlns:views="clr-namespace:DispensingPageType.Views.RecipeParamCfgPage.ParametersAndCalculation"
             x:DataType="vm:TrajectorySequenceModel"
                   xmlns:convert="clr-namespace:DispensingPageType.Converters" 
             x:Class="DispensingPageType.Views.RecipeParamCfgPage.ParametersAndCalculation.LineWorkAreaCfgView">
        
		<!-- 线工作区：属于线的个性化属性在LineWorkAreaViewModel中--> 
 
    <!--纵向排列 -->
 <StackPanel Orientation="Vertical"  HorizontalAlignment="Center" VerticalAlignment="Stretch"   Margin="2 0 0 0"  >
     <!-- 上方显示:轨迹相关信息列表栏 -->
        <!--左侧选项卡显示详情，右侧选项卡显示DataGrid      --> 
                 <TabControl Margin="0" TabStripPlacement="Top"  BorderBrush="#CCCCCC" BorderThickness="1.5"    Width="490"  Height="733" > 
                      
                        <TabItem Header="线列表" FontSize="14"  >   
                            <DockPanel Margin="0" LastChildFill="True" VerticalAlignment="Top"   Height="680" Width="490"   >
                                <!--1. 上方线列表 --> 
                                <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Spacing="1" Margin="1 0 0 1" Height="463" > 
                                    <!--1. 顶部操作菜单（添加按钮）--> 
                                        <StackPanel Orientation="Horizontal" Spacing="1" Margin="1 0 0 1"  >
			                                <Button 
                                            Content="添加直线"
                                            Command="{Binding LineWorkAreaViewModel.AddStraightLineCommand}" 
                                            Classes="DataGrid_btnAddStyle" Width="80" 
                                            />  
                                        <Button 
                                            Content="添加圆"
                                            Command="{Binding LineWorkAreaViewModel.AddCircleCommand}" 
                                            Classes="DataGrid_btnAddStyle" Width="80" /> 
                                            <Button 
                                            Content="添加圆弧"
                                            Command="{Binding LineWorkAreaViewModel.AddCircularArcACommand}" 
                                            Classes="DataGrid_btnAddStyle" Width="80" /> 
                                        <Button 
                                            Content="平移"
                                            Command="{Binding LineWorkAreaViewModel.BatchTranslationCommand}" 
                                            Classes="DataGrid_btnAddStyle" Width="80" /> 
                                        <Button 
                                            Content="删除" 
                                            Command="{Binding LineWorkAreaViewModel.BatchDeleteCommand}" 
                                            Classes="DataGrid_btnAddStyle" Width="80" /> 
                                        </StackPanel> 

                                    <!-- 线轨迹列表   VerticalAlignment="Top"   --> 
                                        <DataGrid    ItemsSource="{Binding LineWorkAreaViewModel.ItemsSource}"
                                            SelectedItem="{Binding LineWorkAreaViewModel.SelectedItem , Mode=TwoWay}"
                                            AutoGenerateColumns="False"
                                            BorderBrush="LightGray"
                                            BorderThickness="1"
                                            IsReadOnly="False" 
                                            SelectionMode="Extended"
                                            RowHeight="40"  Width="480" Height="430"
                                     
                                            CanUserSortColumns="False"  Classes="StyleDataGrid" > 
      
                                            <DataGrid.Columns> 
                                                <!-- 全选列（不变） -->
                                                <DataGridTemplateColumn Width="40" IsReadOnly="True">
                                                    <DataGridTemplateColumn.HeaderTemplate  >
                                                        <DataTemplate>
                                                            <CheckBox Classes="DataGrid_CheckBoxStyle"  
                                                                        IsChecked="{Binding DataContext.LineWorkAreaViewModel.IsSelectAll, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                                        Content="全选"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.HeaderTemplate>
                                                    <DataGridTemplateColumn.CellTemplate >
                                                        <DataTemplate DataType="vm:LineCalculateTrajectoryItemViewModel">
                                                            <CheckBox Classes="DataGrid_CheckBoxStyle" 
                                                                        IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn> 


                                                <!-- 1. 序号（只读） -->
                                                <DataGridTextColumn 
                                                    Header="序号" 
                                                    Binding="{Binding SerialNumber}" 
                                                    Width="68"
                                                    IsReadOnly="True"/> 

                                                <!-- 2. 轨迹ID（只读） -->
                                            <!--     <DataGridTextColumn   Header="线轨迹ID"  Binding="{Binding TrackID}"   Width="100"    IsReadOnly="True"/> -->
                   
                                                <!-- 3. 计算轨迹类型 -->
                                                <DataGridTemplateColumn 
                                                Header="线类型"   Width="86"   > 
                                                    <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate DataType="vm:LineCalculateTrajectoryItemViewModel"> 
                                                            <ComboBox  IsEnabled="False" 
			                                                    Width="78"  Classes="DataGrid_ComboBoxStyle"
		                                                        ItemsSource="{Binding LineCalculateTrajectoryTypeModel.ItemsSource, Mode=OneWay}" 
                                                                SelectedItem="{Binding LineCalculateTrajectoryTypeModel.SelectedItem, Mode=TwoWay}"  > 
				                                                    <ComboBox.ItemTemplate>
					                                                    <DataTemplate   DataType="ui:ComBoxItem">
						                                                    <StackPanel Orientation="Horizontal"  > 
					     	                                                    <TextBlock Text="{Binding DisplayName}" /> 
					                                                        </StackPanel>
					                                                    </DataTemplate>
				                                                    </ComboBox.ItemTemplate>
                                                            </ComboBox> 
                                                    </DataTemplate> 
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                         
                                                <!-- 3. 是否启用 -->
                                                <DataGridTemplateColumn 
                                                    Header="启用"  Width="70"
                                                    >
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate DataType="vm:LineCalculateTrajectoryItemViewModel">
                                                            <!-- 绑定到 IsDispensingViewModel.IsChecked（双向同步） -->
                                                            <ToggleSwitch  
                                                                IsChecked="{Binding IsDispensingViewModel.IsChecked, Mode=TwoWay}" 
                                                                Classes="DataGrid_ToggleSwitchStyle"   OffContent=""  OnContent=""
                                                                Width="50"   MinWidth="50"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                          
                                                    <!-- 操作列（编辑+删除按钮） -->
                                                <DataGridTemplateColumn 
                                                    Header="操作" 
                                                    Width="214" 
                                                    IsReadOnly="True">  <!-- 模板列设为只读，避免单元格编辑冲突 -->
                                                        <!-- 定义表头样式，设置文本居中 --> 
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate DataType="vm:LineCalculateTrajectoryItemViewModel">
                                                            <StackPanel Orientation="Horizontal" Spacing="2" > 
                                                                <Button 
                                                                    Content="上移"  
                                                                    Command="{Binding DataContext.LineWorkAreaViewModel.UpMoveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}"  
                                                                Classes="btnEdit_DataGrid"  />

                                                                <Button 
                                                                    Content="下移"  
                                                                    Command="{Binding DataContext.LineWorkAreaViewModel.DownMoveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}"  
                                                                Classes="btnEdit_DataGrid"  />

                                                                <Button 
                                                                    Content="平移"  
                                                                    Command="{Binding DataContext.LineWorkAreaViewModel.TranslationCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}"  
                                                                Classes="btnEdit_DataGrid"  />

                                                                    <!-- 删除按钮：绑定ViewModel的DeleteCommand，传递当前行数据 + 禁用控制   -->
                                                                <Button 
                                                                    Content="删除" 
                                                                    Command="{Binding  DataContext.LineWorkAreaViewModel.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                    CommandParameter="{Binding}" 
                                                                    Classes="DataGrid_btnDeleteStyle" > 
                                                                </Button>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                            </DataGrid.Columns> 
                                        </DataGrid> 
                                </StackPanel> 
                                 

                                    <!--下方显示点明细列表和线详情  --> 
                                    <StackPanel  Orientation="Vertical" Spacing="0" Margin="0 0 0 0"  VerticalAlignment="Bottom"  Width="490"   Height="217">
			                            <!--左侧选项卡显示详情，右侧选项卡显示DataGrid      --> 
                                            <TabControl Margin="0" Name="MyTabControl"   SelectedIndex ="{Binding LineWorkAreaViewModel.SelectedTabIndex}"  TabStripPlacement="Top"  BorderBrush="#CCCCCC" BorderThickness="1.5" Height="217"  > 
                                                <TabItem Header="点列表" FontSize="14" Margin="0">   
                                                        <DataGrid   ItemsSource="{Binding LineWorkAreaViewModel.SelectedItem.PointInfoItems}"
                                                            AutoGenerateColumns="False"
                                                            BorderBrush="LightGray" 
                                                            BorderThickness="1"
                                                            IsReadOnly="False" 
                                                            SelectionMode="Single"
                                                            SelectedItem="{Binding LineWorkAreaViewModel.SelectedItem.SelectedPointInfo, Mode=TwoWay}"
                                                            RowHeight="40"  Width="480"   Height="140"
                                                            CanUserResizeColumns="True"      
                                                            CanUserSortColumns="True"  Classes="StyleDataGrid" > 
      
                                                            <DataGrid.Columns>   
                                                                            <!-- 1. 序号（只读） -->
                                                                <DataGridTextColumn 
                                                                    Header="序号" 
                                                                    Binding="{Binding SerialNumber}" 
                                                                    Width="68"
                                                                    IsReadOnly="True"  /> 
                        
                                                                    <!--  点ID、
                                                                    <DataGridTextColumn   Header="ID"  Binding="{Binding PointID}"   Width="100"    IsReadOnly="True"/> -->
 
                     
                                                                <DataGridTemplateColumn 
                                                                    Header="点类型"     Width="98"   > 
                                                                        <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate DataType="vm:LineTrajectoryItemPointInfoViewModel">
                                                                                <ComboBox  IsEnabled="False" 
			                                                                    Width="88"  Classes="DataGrid_ComboBoxStyle" 
		                                                                        ItemsSource="{Binding LinePointKindModel.ItemsSource, Mode=TwoWay}" 
                                                                                SelectedItem="{Binding LinePointKindModel.SelectedItem, Mode=TwoWay}"  > 
				                                                                    <ComboBox.ItemTemplate>
					                                                                        <DataTemplate   DataType="ui:ComBoxItem">
						                                                                    <StackPanel Orientation="Horizontal"  > 
					     	                                                                    <TextBlock Text="{Binding DisplayName}" /> 
					                                                                        </StackPanel>
					                                                                    </DataTemplate>
				                                                                    </ComboBox.ItemTemplate>
                                                                                </ComboBox>  
                                                                        </DataTemplate> 
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn> 

                                                                <DataGridTemplateColumn 
                                                                    Header="X"  Width="104"  >
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate DataType="vm:LineTrajectoryItemPointInfoViewModel"> 
                                                                                <NumericUpDown  
                                                                                Value="{Binding XViewModel.Value, Mode=TwoWay}"
                                                                                Minimum="{Binding XViewModel.Minimum}"
                                                                                Increment="{Binding XViewModel.Increment}" 
                                                                                Width="100" Classes="DataGrid_NumericUpDownStyle" />  
                                    
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                         
                                                                <DataGridTemplateColumn 
                                                                    Header="Y"   Width="104"
                                                                    >
                                                                    <DataGridTemplateColumn.CellTemplate  >
                                                                        <DataTemplate DataType="vm:LineTrajectoryItemPointInfoViewModel" > 
					                                                            <NumericUpDown 
                                                                                Value="{Binding YViewModel.Value, Mode=TwoWay}"
                                                                                Minimum="{Binding YViewModel.Minimum}"
                                                                                Increment="{Binding YViewModel.Increment}"
                                                                                HorizontalAlignment="Stretch"
                                                                                    Width="100"  Classes="DataGrid_NumericUpDownStyle" />           
                                 
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                         
                                                                <DataGridTemplateColumn 
                                                                    Header="Z"   Width="104">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate DataType="vm:LineTrajectoryItemPointInfoViewModel">  
                                                                            <NumericUpDown 
                                                                                Value="{Binding ZViewModel.Value, Mode=TwoWay}"
                                                                                Minimum="{Binding ZViewModel.Minimum}"
                                                                                Increment="{Binding ZViewModel.Increment}"
                                                                                HorizontalAlignment="Stretch"
                                                                                    Width="100" Classes="DataGrid_NumericUpDownStyle" />  
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                            
                                                            </DataGrid.Columns> 
                                                        </DataGrid>
                                                </TabItem> 

                                        
                                                <TabItem Header="线轨迹详情" FontSize="14" Margin="0"> 
                                                        <!--点工作区：属于点的个性化属性在PointTrajectoryCfgViewModel中   LineWorkAreaViewModel.SelectedItem.SerialNumberViewModel -->  
                                                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,Auto"
                                                                RowSpacing="0"  HorizontalAlignment="Left"  Height="140"  Margin="0"  >
                  
                                                       <custom:TextBlockControl
                                                            Grid.Row="0"  Grid.Column="0" 
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center" 
			                                                LabelName="序号"
			                                                WidthLevel="Small7"  
			                                                ViewModel="{Binding LineWorkAreaViewModel.SelectedItem.SerialNumberViewModel}"
			                                                />  
                                                                           
                                                                <!-- 线类型 -->  
                                                        <custom:ComboxControl   Grid.Row="0"  Grid.Column="1"  
					                                            LabelName="线类型"
					                                            WidthLevel="Small7"   IsEnabled="False"
					                                            ViewModel="{Binding  LineWorkAreaViewModel.SelectedItem.LineCalculateTrajectoryTypeModel  , Mode=TwoWay }" 
					                                            />  
                                                                        <!-- 绑定到 IsDispensingViewModel.IsChecked（双向同步） --> 
                                                            <custom:ToggleSwitchControl 
                                                                    Grid.Row="1"  Grid.Column="0"  
					                                            LabelName="是否启用"
					                                            WidthLevel="Small7" 
					                                            ViewModel="{Binding LineWorkAreaViewModel.SelectedItem.IsDispensingViewModel , Mode=TwoWay}" />
              
                                                                    <!--绑定到 SelectedStyleModel（下拉数据源+选中项）-->  
                                                        <custom:ComboxControl   Grid.Row="1"  Grid.Column="1"  
					                                            LabelName="样式"
					                                            WidthLevel="Small7"  
					                                            ViewModel="{Binding LineWorkAreaViewModel.SelectedItem.SelectedStyleModel  , Mode=TwoWay }" 
					                                            /> 

                                                            <!--重量单位-->  
                                                        <custom:ComboxControl   Grid.Row="2"  Grid.Column="0"  
				                                                LabelName="重量单位"   WidthLevel="Small7" 
				                                                ViewModel="{Binding LineWorkAreaViewModel.SelectedItem.WeightUnitModel , Mode=TwoWay }" 
				                                                /> 

                                                            <!--重量-->  
                                                        <custom:NumericControl Grid.Row="2"  Grid.Column="1" 
                                                                ViewModel="{Binding LineWorkAreaViewModel.SelectedItem.WeightViewModel, Mode=TwoWay}" 
					                                            LabelName="重量"  WidthLevel="Small7"  />  

                                                    </Grid> 
                                                </TabItem>  
                                        </TabControl>
               
                                    </StackPanel> 

                            </DockPanel>  
                      
                        </TabItem> 

                      <TabItem Header="轨迹详情" FontSize="14">  
                               <!-- 轨迹详情  BorderBrush="#CCCCCC" BorderThickness="1.5"  -->  
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,Auto"
                                          RowSpacing="0"  HorizontalAlignment="Left"    Margin="0"  >
                 
                                    <custom:TextBlockControl
                                            Grid.Row="0"  Grid.Column="0" 
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" 
			                                LabelName="序号"
			                                WidthLevel="Small7"  
			                                ViewModel="{Binding SerialNumberViewModel}"
			                                /> 

                                              <!-- 类型 -->  
                                    <custom:ComboxControl   Grid.Row="0"  Grid.Column="1"  
					                        LabelName="类型"
					                        WidthLevel="Small7"   IsEnabled="False"
					                        ViewModel="{Binding CalculateTrajectoryTypeModel  , Mode=TwoWay }" 
					                        />  

                                                 <!-- 绑定到 IsDispensingViewModel.IsChecked（双向同步） --> 
                                      <custom:ToggleSwitchControl 
                                             Grid.Row="1"  Grid.Column="0"  
					                        LabelName="是否点胶"
					                          WidthLevel="Small7" 
					                        ViewModel="{Binding IsDispensingViewModel, Mode=TwoWay}" />
              
                                               <!--绑定到 SelectedStyleModel（下拉数据源+选中项）-->  
                                    <custom:ComboxControl   Grid.Row="1"  Grid.Column="1"  
					                        LabelName="样式"
					                        WidthLevel="Small7"  
					                        ViewModel="{Binding SelectedStyleModel  , Mode=TwoWay }" 
					                        /> 

                                       <!--重量单位-->  
                                    <custom:ComboxControl   Grid.Row="2"  Grid.Column="0"  
				                            LabelName="重量单位"   WidthLevel="Small7" 
				                            ViewModel="{Binding WeightUnitModel , Mode=TwoWay }" 
				                            /> 

                                        <!--重量-->  
                                    <custom:NumericControl Grid.Row="2"  Grid.Column="1" 
                                            ViewModel="{Binding WeightViewModel, Mode=TwoWay}" 
					                        LabelName="重量"  WidthLevel="Small7"  />  

                                            
                                </Grid> 
                        </TabItem>  
                </TabControl>


      
   </StackPanel>

</UserControl>
