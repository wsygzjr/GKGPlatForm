<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="using:Griffins.UI"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="clr-namespace:Griffins.CompUI.TestGlueDirectWorkMM.RecipeCfgPage.ViewModels.TemplateSubPage.Mark"
             xmlns:griffinsUI="clr-namespace:Griffins.UI.Common;assembly=Griffins.UI"   
			 xmlns:custom="clr-namespace:Griffins.UI;assembly=Griffins.UI2"
             xmlns:views="clr-namespace:DispensingPageType.Views.RecipeParamCfgPage.ParametersAndCalculation"
             x:DataType="vm:MarkPointViewModel" 
             x:Class="DispensingPageType.Views.RecipeParamCfgPage.ParametersAndCalculation.MarkPointRecognizeCfgInfoView">
 
    <!--Mark设置栏：当前选中的Mark点参数设置栏：卡片 -->

	 
    <!-- 2.1 Mark基础配置参数-视图模型 3行2列  Height="85" -->
	<Grid   Grid.Row="0"  Grid.Column="1"  RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto"
			RowSpacing="0"  HorizontalAlignment="Left"  VerticalAlignment="Top" Width="985" >
		<!--Mark方式-下拉框数据模型 MarkModeModel -->

		 <custom:ComboxControl  Margin="5 0 5 1" 
		    Grid.Row="0"  Grid.Column="0"
		    HorizontalAlignment="Stretch"
		    HorizontalContentAlignment="Stretch" 
            Foreground="#333333"
            Background ="Transparent"
		    VerticalAlignment="Stretch"
		    LabelName="Mark操作类型:"
		    WidthLevel="Medium"
		    ViewModel="{Binding MarkOpKindModel }" />  
            

<!--    <StackPanel Orientation="Horizontal"    Grid.Row="0"  Grid.Column="0">
		    <TextBlock Text="重量" VerticalAlignment="Top"  />
            <ComboBox  IsEnabled="True" 
		        Width="68"  Classes="DataGrid_ComboBoxStyle"
		        ItemsSource="{Binding MarkOpKindModel.ItemsSource, Mode=OneWay}" 
                SelectedItem="{Binding MarkOpKindModel.SelectedItem, Mode=TwoWay}"  > 
			        <ComboBox.ItemTemplate>
				        <DataTemplate   DataType="ui:ComBoxItem">
					        <StackPanel Orientation="Horizontal"  > 
					            <TextBlock Text="{Binding DisplayName}" /> 
					        </StackPanel>
				        </DataTemplate>
			        </ComboBox.ItemTemplate>
            </ComboBox>       		
    </StackPanel>  -->                                  
	     
        
   <!--MarkPointRecognizeCfgInfoView绑定的数据源为：MarkPointListViewModel->SelectedItem->MarkPositionOperateViewModel-->
        <!--位置调整栏-->
        <Grid   Grid.Row="1"  Grid.Column="0"  RowDefinitions="Auto,Auto" ColumnDefinitions="Auto"
            RowSpacing="0"  HorizontalAlignment="Left"  VerticalAlignment="Top"  Height="105" Width="580" > 
             <!--   --><!-- 坐标表头 --><!--
                <griffinsUI:PositionTeachHeaderView    Grid.Row="0"  Grid.Column="0"  
                    Margin="5" Height="35" Width="580"  />   
                --><!-- 坐标数据  --><!--
                <griffinsUI:PositionTeachView    Grid.Row="1"  Grid.Column="0" 
                    DataContext="{Binding  . }" 
                    Margin="5" Height="50" Width="580"  />   -->
        </Grid>

        <!--按钮栏 --> 
        <StackPanel Grid.Row="2"  Grid.Column="0"  Orientation="Horizontal"  Spacing="0" Margin="5 0 5 1"    HorizontalAlignment="Center" > 
                    <Button Content="创建模板" Command="{Binding CreateTemplateCommand}" Classes="btnAdd" MinWidth="60" Padding="2 3"/> 
                    <Button Content="测试模版" Command="{Binding TestTemplateCommand}" Classes="btnAdd" MinWidth="60" Padding="2 3"/> 
                    <Button Content="搜索定位" Command="{Binding SearchLocationCommand}" Classes="btnAdd" MinWidth="60" Padding="2 3"/>  
        </StackPanel>


	</Grid>

</UserControl>
