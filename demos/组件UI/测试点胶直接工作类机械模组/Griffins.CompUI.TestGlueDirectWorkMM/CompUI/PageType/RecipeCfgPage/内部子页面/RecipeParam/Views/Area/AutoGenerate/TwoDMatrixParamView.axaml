<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="clr-namespace:Griffins.CompUI.TestGlueDirectWorkMM.RecipeCfgPage.ViewModels.Area"
             xmlns:gkgUI="clr-namespace:Griffins.UI.General;assembly=PageTypeSimple"   
             xmlns:views="clr-namespace:DispensingPageType.Views.RecipeParamCfgPage.ParametersAndCalculation"
             x:DataType="vm:TwoDMatrixParamViewModel"
             x:Class="DispensingPageType.Views.RecipeParamCfgPage.ParametersAndCalculation.TwoDMatrixParamView">

    
          <StackPanel Orientation="Vertical" Spacing="4" Margin="2" VerticalAlignment="Top" HorizontalAlignment="Left"    Height="728"  Width="660">         
         
              
			<!-- 一维矩阵页面 -->
				<views:OneDMatrixParamView  HorizontalAlignment="Left"
							DataContext="{Binding  }" 
							Margin="2"  BorderBrush="#CCCCCC" BorderThickness="1.5" Width="660"/>
              
			<!--一维矩阵参数-->
				<TextBlock Text="二维矩阵参数栏" VerticalAlignment="Center" HorizontalAlignment="Left"   Width="200" Margin="0 8 0 2" />
                
				<views:DMatrixParamView  HorizontalAlignment="Left"
							DataContext="{Binding TowOfDMatrixParamViewModel}" 
							Margin="2"  BorderBrush="#CCCCCC" BorderThickness="1.5" Width="660"/>
			  	
       </StackPanel>
</UserControl>
