<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="using:DispensingPageType.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="clr-namespace:Griffins.CompUI.TestGlueDirectWorkMM.RecipeCfgPage.ViewModels.DatumPoint"
             xmlns:gkgUI="clr-namespace:Griffins.UI.General;assembly=PageTypeSimple"
             xmlns:local="using Griffins.UI.General"   
             xmlns:views="clr-namespace:DispensingPageType.Views.RecipeParamCfgPage.ParametersAndCalculation"
             x:DataType="vm:DatumPointConfigInfoViewModel"
             x:Class="DispensingPageType.Views.RecipeParamCfgPage.ParametersAndCalculation.DatumPointConfigInfoView">

   
   <!--  基准点 -->
 <StackPanel  Orientation="Horizontal"  Spacing="0" Margin="1 0 0 1"   HorizontalAlignment="Left" >
		 
   	     <!--左侧显示：基准点坐标项配置 ： 垂直排列-->   
        <DockPanel Margin="0" LastChildFill="True"  VerticalAlignment="Top" HorizontalAlignment="Left" Height="714" Width="800"   >  
              <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"  Spacing="0" Margin="1 0 0 1" Width="598"  HorizontalAlignment="Left" > 
                            <Button Content="添加"  Command="{Binding AddCommand}"  Classes="DataGrid_btnAddStyle" MinWidth="60" />  
              </StackPanel>   

              <!-- 左侧显示DataGrid 绑定数据源 -->
        <DataGrid ItemsSource="{Binding CamreaPositionViewModels }"
                  SelectedItem="{Binding SelectedItem , Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  BorderBrush="LightGray"
                  BorderThickness="1"
                  IsReadOnly="False"
                  SelectionMode="Extended"
                  RowHeight="40" Width="585" Height="716"
                  CanUserResizeColumns="True" VerticalAlignment="Top"
                  CanUserSortColumns="True" HorizontalAlignment="Left" Margin="0,2,2,2" Classes="StyleDataGrid">

            <DataGrid.Columns>
                <!-- 坐标数据列（自定义表头） -->
                <DataGridTemplateColumn Width="510" IsReadOnly="True">
                    <!-- 自定义表头模板 -->
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                           <!-- --><!-- 复用PositionTeachHeaderView作为表头 --><!--
                            <gkgUI:PositionTeachHeaderView 
                                Height="35" Width="490"
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>-->
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    
                    <!-- 单元格模板（原有内容） -->
                    <DataGridTemplateColumn.CellTemplate>
                       <!-- <DataTemplate DataType="viewmodels:CamreaPositionViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="0" Margin="1 0 0 1" HorizontalAlignment="Left">
                                <gkgUI:PositionTeachView
                                    DataContext="{Binding}"
                                    Margin="0" Height="38" Width="490"/>
                            </StackPanel>
                        </DataTemplate>-->
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 操作列（自定义表头） -->
                <DataGridTemplateColumn Width="70" IsReadOnly="True"> 
                    <!-- 自定义操作列表头 -->
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <!-- 自定义表头样式（可替换为任意控件） -->
                            <TextBlock Text="操作" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="12" FontWeight="Medium"/> 
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    
                    <!-- 单元格模板（ 删除按钮） -->
                    <DataGridTemplateColumn.CellTemplate>
                      <!--  <DataTemplate DataType="viewmodels:CamreaPositionViewModel">
                            <Button Content="×" Width="35" Height="35" Margin="1 2 2 1"
                                    FontSize="12" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    Classes="DataGrid_btnDeleteStyle"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>-->
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

     </DockPanel>  
   
    <!--右侧显示相机栏  -->  
     <StackPanel Orientation="Vertical"  HorizontalAlignment="Left"   Margin="10 10 10 10"   Height="714"   Width="816">  
		<!-- <gkgUI:CameraShowView  HorizontalAlignment="Left"  
            DataContext="{x:Static local:GlobalVisionViewModel.CameraShowViewModel}" 
			Margin="2" Height="610"  Width="815" /> -->
     </StackPanel>
</StackPanel>
</UserControl>
