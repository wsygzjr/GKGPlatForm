<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:ui="clr-namespace:Griffins.UI;assembly=Griffins.UI2"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="clr-namespace:Griffins.CompUI.TestGlueDirectWorkMM.RecipeCfgPage.ViewModels.TemplateSubPage.Command"
             xmlns:vm1="using:Griffins.CompUI.TestGlueDirectWorkMM.RecipeCfgPage.ViewModels.TemplateSubPage.TrajectorySequence"
             xmlns:gkgUI="clr-namespace:Griffins.UI.General;assembly=PageTypeSimple"   
             xmlns:views="clr-namespace:DispensingPageType.Views.RecipeParamCfgPage.ParametersAndCalculation"
             x:DataType="vm:DispensingTrajectoryWorkAreaViewModel"
             xmlns:custom="clr-namespace:Griffins.UI;assembly=Griffins.UI2"   
             xmlns:convert="clr-namespace:DispensingPageType.Converters" 
             x:Class="DispensingPageType.Views.RecipeParamCfgPage.ParametersAndCalculation.DispensingTrajectoryWorkAreaView">
	
    
          <!-- 轨迹列表：横向排列 --> 
 <StackPanel Orientation="Vertical"  HorizontalAlignment="Left" VerticalAlignment="Stretch"    Margin="0 0 0 0"   Width="870"   Height="293"  >
        <!-- 左侧显示:轨迹列表栏 -->
    <DockPanel Margin="0" LastChildFill="True"  Width="868"     VerticalAlignment="Top" HorizontalAlignment="Left"    Height="240"  >  
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"  Spacing="0" Margin="1 0 0 1"  Height="35"   HorizontalAlignment="Left" >  
              <Button Content="添加轨迹" Command="{Binding AddTrajectorySequenceCommand}"  Classes="DataGrid_btnAddStyle" MinWidth="60" /> 
              <Button Content="删除" Command="{Binding BatchDeleteCommand}" Classes="DataGrid_btnAddStyle" MinWidth="60" />    
          </StackPanel>

            <!--左侧显示DataGrid 绑定数据源    --> 
          <StackPanel  Spacing="0" Margin="1 1 1 1" Width="866"  Height="205"  >
                  <DataGrid    ItemsSource="{Binding ItemsSource }"
                        SelectedItem="{Binding SelectedItem , Mode=TwoWay}"
                        AutoGenerateColumns="False"
                        BorderBrush="LightGray"
                        BorderThickness="1"
                        IsReadOnly="False" 
                        SelectionMode="Single"
                        RowHeight="40"  Width="864"   Height="205"
                         VerticalAlignment="Top"
                        CanUserSortColumns="False"  HorizontalAlignment="Left"  Margin="6,0,0,1"  Classes="StyleDataGrid"  > 
      
                    <DataGrid.Columns> 
                       <!-- 全选列（不变） -->
                    <DataGridTemplateColumn Width="70" IsReadOnly="True">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox Classes="CheckBoxStyle"  
                                          IsChecked="{Binding DataContext.IsSelectAll, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                          Content="全选"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="vm1:TrajectorySequenceBaseModel">
                                <CheckBox Classes="CheckBoxStyle" 
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn> 

                        <!-- 1. 序号（只读） -->
                      <DataGridTextColumn 
                                Header="序号" 
                                Binding="{Binding SerialNumber}" 
                                Width="68"
                                IsReadOnly="True"  /> 

                        <!-- 2. 子模板ID（只读） -->
                    <!--    <DataGridTextColumn   Header="轨迹ID"  Binding="{Binding TrackID }"   Width="100"    IsReadOnly="True"/> -->
                          
                           <!-- 3. 计算轨迹类型（可编辑：ComboBox） -->
                    <DataGridTemplateColumn 
                        Header="类型"   Width="70"   > 
                         <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="vm1:TrajectorySequenceModel"> 
                                   <ComboBox  IsEnabled="False" 
			                            Margin="2"  Width="66" 
		                                ItemsSource="{Binding CalculateTrajectoryTypeModel.ItemsSource, Mode=OneWay}" 
                                        SelectedItem="{Binding CalculateTrajectoryTypeModel.SelectedItem, Mode=TwoWay}"  > 
				                            <ComboBox.ItemTemplate>
					                            <DataTemplate   DataType="ui:ComBoxItem">
						                            <StackPanel Orientation="Horizontal" Spacing="2"> 
					     	                            <TextBlock Text="{Binding DisplayName}" /> 
					                                </StackPanel>
					                            </DataTemplate>
				                            </ComboBox.ItemTemplate>
                                   </ComboBox> 
                            </DataTemplate> 
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 3. 是否点胶（可编辑：ToggleSwitch） -->
                    <DataGridTemplateColumn 
                        Header="点胶"  Width="70"
                       >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="vm1:TrajectorySequenceModel">
                                <!-- 绑定到 IsDispensingViewModel.IsChecked（双向同步） -->
                                <ToggleSwitch   IsEnabled="False" 
                                    IsChecked="{Binding IsDispensingViewModel.IsChecked, Mode=TwoWay}"
                                    HorizontalAlignment="Center"
                                    OffContent=""  OnContent=""
                                    MinWidth="60"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 4. 样式  --> 
                   <DataGridTemplateColumn 
                        Header="样式"   Width="160"   > 
                         <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="vm1:TrajectorySequenceModel"> 
                                <ComboBox    IsEnabled="False" 
			                        Classes="DataGrid_ComboBoxStyle" Width="150" 
		                        ItemsSource="{Binding SelectedStyleModel.ItemsSource, Mode=TwoWay}" 
                                SelectedItem="{Binding SelectedStyleModel.SelectedItem, Mode=TwoWay}"  > 
				                    <ComboBox.ItemTemplate>
					                    <DataTemplate   DataType="ui:ComBoxItem">
						                    <StackPanel Orientation="Horizontal"  > 
					     	                    <TextBlock Text="{Binding DisplayName}" /> 
					                        </StackPanel>
					                    </DataTemplate>
				                    </ComboBox.ItemTemplate>
                            </ComboBox> 
                            </DataTemplate> 
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                     
                    <!-- 5. 重量单位  -->
                     <DataGridTemplateColumn 
                        Header="重量单位"   Width="70"   > 
                         <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="vm1:TrajectorySequenceModel"> 
                                   <ComboBox  IsEnabled="False" 
			                            Margin="2"  Width="66" 
		                                ItemsSource="{Binding WeightUnitModel.ItemsSource, Mode=OneWay}" 
                                        SelectedItem="{Binding WeightUnitModel.SelectedItem, Mode=TwoWay}"  > 
				                            <ComboBox.ItemTemplate>
					                            <DataTemplate   DataType="ui:ComBoxItem">
						                            <StackPanel Orientation="Horizontal" Spacing="2"> 
					     	                            <TextBlock Text="{Binding DisplayName}" /> 
					                                </StackPanel>
					                            </DataTemplate>
				                            </ComboBox.ItemTemplate>
                                   </ComboBox> 
                            </DataTemplate> 
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                      
                    <!-- 6. 重量值（可编辑：NumericUpDown） -->
                    <DataGridTemplateColumn 
                        Header="重量" 
                        Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="vm1:TrajectorySequenceModel">
                                <!-- 绑定到 WeightViewModel.Value（支持数值输入/调节） -->
                                <NumericUpDown  IsEnabled="False" 
                                    Value="{Binding WeightViewModel.Value, Mode=TwoWay}"
                                    Minimum="{Binding WeightViewModel.Minimum}"
                                    Increment="{Binding WeightViewModel.Increment}"
                                    HorizontalAlignment="Stretch"
                                    Padding="2"  Width="130" />  
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                                 
                        <!-- 操作列（编辑+删除按钮） -->
                        <DataGridTemplateColumn 
                            Header="操作" 
                            Width="190" 
                            IsReadOnly="True">  <!-- 模板列设为只读，避免单元格编辑冲突 -->
                             <!-- 定义表头样式，设置文本居中 --> 
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="vm1:TrajectorySequenceBaseModel">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="5 0"> 
                                         <Button 
                                            Content="上移"  
                                            Command="{Binding DataContext.UpMoveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"  
                                            Classes="btnEdit_DataGrid"  />

                                        <Button 
                                            Content="下移"  
                                            Command="{Binding DataContext.DownMoveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"  
                                            Classes="btnEdit_DataGrid"  />


                                          <!-- 删除按钮：绑定ViewModel的DeleteCommand，传递当前行数据 + 禁用控制 -->
                                        <Button 
                                            Content="删除" 
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" 
                                            Classes="DataGrid_btnDeleteStyle" > 
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                     
                    </DataGrid.Columns> 
                </DataGrid>
         </StackPanel>
     </DockPanel>  
       
     <StackPanel Orientation="Horizontal"  HorizontalAlignment="Center"   Margin="0 0 0 0"   Width="638"  Height="50">
	     <custom:ComboxControl 
		    HorizontalAlignment="Left"
		    HorizontalContentAlignment="Center"
		    VerticalAlignment="Center"
		    VerticalContentAlignment="Center"
		    LabelName="阀号"
		    WidthLevel="Small"
		    ViewModel="{Binding ValveInfoModel }" /> 
		
		<!-- 偏差值报警-数字输入框数据模型  -->
		<custom:NumericControl 
			HorizontalAlignment="Left"
		    HorizontalContentAlignment="Center"
		    VerticalAlignment="Center"
		    VerticalContentAlignment="Center"
		    LabelName="循环次数"
		    WidthLevel="Small" 
		    ViewModel="{Binding CycleCountViewModel }"
		    />   
      </StackPanel> 

   </StackPanel>
</UserControl>