<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
	    xmlns:convert="clr-namespace:PageMngControl.Converters"
		xmlns:vm="clr-namespace:Griffins.CompUI.TestGlueDirectWorkMM.RecipeCfgPage.ViewModels.TemplateSubPage.TrajectorySequence"
             x:DataType="vm:TranslationPositionViewModel" 
        xmlns:custom="clr-namespace:Griffins.UI;assembly=Griffins.UI2"   
        x:Class="DispensingPageType.Views.RecipeParamCfgPage.ParametersAndCalculation.TranslationPositionWindow"
        Title="">
       
    <!-- 平移量设置弹窗，主布局：垂直排列 表单、按钮区   -->
    <StackPanel Margin="10,25,10,25" HorizontalAlignment="Center"   >
         
        <!-- 2. 表单内容   -->
        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto"
              RowSpacing="0"  HorizontalAlignment="Center" >
            <!-- X -->
             <custom:NumericControl
            Grid.Row="0"  Grid.Column="0" 
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
			Name="AxisCountViewModel1"
			LabelName="X(mm)"
			WidthLevel="Small1"  
			ViewModel="{Binding XViewModel}"
			/>

       
             <custom:NumericControl
            Grid.Row="1"  Grid.Column="0" 
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" 
			LabelName="Y(mm)"
			WidthLevel="Small1"  
			ViewModel="{Binding YViewModel }"
			/>
              <!-- Z --> 
             <custom:NumericControl
            Grid.Row="2"  Grid.Column="0" 
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" 
			LabelName="Z(mm)"
			WidthLevel="Small1"  
			ViewModel="{Binding ZViewModel }"
			/> 
             
        </Grid>

        <!-- 3. 按钮区（保存/取消） -->
        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0 0 0 0">
            <Button 
                Content="取消" 
                Command="{Binding CancelCommand}"
                Classes="btnCancel"  />
             
            <Button 
                Content="保存"    Classes="btnSave"
                Command="{Binding SaveCommand}"  
                Cursor="Hand"> 
            </Button>
        </StackPanel>
    </StackPanel>
 	
</Window>
