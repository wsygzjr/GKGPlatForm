<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="clr-namespace:Griffins.CompUI.AxisDebug.CompUI_AxisDebug.PageType.InitCfgPage.IOInDebugging.ViewModels"
             xmlns:custom="using:GKG.UI"
             x:DataType="vm:IOInDebuggingCompUIViewModel"
             x:Class="Griffins.CompUI.AxisDebug.CompUI_AxisDebug.PageType.InitCfgPage.IOInDebugging.Views.IOInDebuggingCompUIView">

    <Grid RowDefinitions="Auto, *">
        <custom:ToggleSwitchControl Grid.Row="0" 
                                    LabelName="是否有B轨:" 
                                    WidthLevel="Medium"
                                    ViewModel="{Binding HasTrackBViewModel}" 
                                    HorizontalAlignment="Left"
                                    Margin="10,10,10,20"/>

        <Grid Grid.Row="1" ColumnDefinitions="*, 16, *, 16, *" Margin="12,0,12,12">
            <Border Grid.Column="0" BorderBrush="#D3D3D3" BorderThickness="1" Background="White">
                <Grid RowDefinitions="Auto, *">
                    <Border Background="#D9D9D9" BorderBrush="#D3D3D3" BorderThickness="0,0,0,1" Padding="0">
                        <Grid ColumnDefinitions="*,60">
                            <Border Background="#D9D9D9" />
                            <Border Grid.Column="1" Background="#D9D9D9" BorderBrush="#C8C8C8" BorderThickness="1,0,0,0" />
                            <TextBlock Text="端口名称" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8,8" FontWeight="Bold" Foreground="#333333" />
                            <TextBlock Grid.Column="1" Text="感应器" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#333333" />
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding CommonSensors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E6E6E6" BorderThickness="0,0,0,1" Padding="0" Background="Transparent">
                                        <Grid ColumnDefinitions="*,60" MinHeight="34">
                                            <Border Background="#EAF4FF" />
                                            <Border Grid.Column="1" Background="White" BorderBrush="#D9D9D9" BorderThickness="1,0,0,0" />
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8,6" Foreground="#333333" />
                                            <Ellipse Grid.Column="1" Width="14" Height="14" Fill="{Binding StatusColor}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2" BorderBrush="#D3D3D3" BorderThickness="1" Background="White">
                <Grid RowDefinitions="Auto, *">
                    <Border Background="#D9D9D9" BorderBrush="#D3D3D3" BorderThickness="0,0,0,1" Padding="0">
                        <Grid ColumnDefinitions="*,60">
                            <Border Background="#D9D9D9" />
                            <Border Grid.Column="1" Background="#D9D9D9" BorderBrush="#C8C8C8" BorderThickness="1,0,0,0" />
                            <TextBlock Text="端口名称" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8,8" FontWeight="Bold" Foreground="#333333" />
                            <TextBlock Grid.Column="1" Text="A轨感应器" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#333333" />
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding TrackASensors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E6E6E6" BorderThickness="0,0,0,1" Padding="0" Background="Transparent">
                                        <Grid ColumnDefinitions="*,60" MinHeight="34">
                                            <Border Background="#EAF4FF" />
                                            <Border Grid.Column="1" Background="White" BorderBrush="#D9D9D9" BorderThickness="1,0,0,0" />
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8,6" Foreground="#333333" />
                                            <Ellipse Grid.Column="1" Width="14" Height="14" Fill="{Binding StatusColor}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Panel Grid.Column="3" IsVisible="{Binding IsTrackBVisible}"/>

            <Border Grid.Column="4" BorderBrush="#D3D3D3" BorderThickness="1" Background="White" IsVisible="{Binding IsTrackBVisible}">
                <Grid RowDefinitions="Auto, *">
                    <Border Background="#D9D9D9" BorderBrush="#D3D3D3" BorderThickness="0,0,0,1" Padding="0">
                        <Grid ColumnDefinitions="*,60">
                            <Border Background="#D9D9D9" />
                            <Border Grid.Column="1" Background="#D9D9D9" BorderBrush="#C8C8C8" BorderThickness="1,0,0,0" />
                            <TextBlock Text="端口名称" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8,8" FontWeight="Bold" Foreground="#333333" />
                            <TextBlock Grid.Column="1" Text="B轨感应器" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#333333" />
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding TrackBSensors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E6E6E6" BorderThickness="0,0,0,1" Padding="0" Background="Transparent">
                                        <Grid ColumnDefinitions="*,60" MinHeight="34">
                                            <Border Background="#EAF4FF" />
                                            <Border Grid.Column="1" Background="White" BorderBrush="#D9D9D9" BorderThickness="1,0,0,0" />
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8,6" Foreground="#333333" />
                                            <Ellipse Grid.Column="1" Width="14" Height="14" Fill="{Binding StatusColor}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
