<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Company>Griffins</Company>
    <Copyright>Copyright © Griffins 2025</Copyright>
    <AssemblyVersion>7.1.0.0</AssemblyVersion>
    <FileVersion>7.1.0.0</FileVersion>
    <AssemblyTitle>Griffins.CompUI.RWS</AssemblyTitle>
    <Product>Griffins.CompUI.RWS</Product>
    <AssemblyName>Griffins.CompUI.RWS</AssemblyName>
    <RootNamespace>Griffins.CompUI.RWS</RootNamespace>
    <OutputType>Library</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>disable</Nullable>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <OutputPath>F:\Griffins7.1\Bin\Share\CompUI\</OutputPath>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="App.axaml.cs" />
    <Compile Remove="Program.cs" />
    <Compile Remove="ViewLocator.cs" />
    <Compile Remove="ViewModels\**\*.cs" />
    <Compile Remove="Views\**\*.cs" />
    <Compile Remove="CompUI_RWS\PageType\InitCfgPage\SingleTrackStation\**\*.cs" />
    <Compile Remove="CompUI_RWS\PageType\InitCfgPage\SingleControlSingleLimit\**\*.cs" />
    <Compile Remove="CompUI_RWS\PageType\InitCfgPage\SingleControlDoubleLimit\**\*.cs" />
    <Compile Remove="CompUI_RWS\PageType\InitCfgPage\DoubleControlSingleLimit\**\*.cs" />
    <Compile Remove="CompUI_RWS\PageType\InitCfgPage\DoubleControlDoubleLimit\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <AvaloniaXaml Remove="App.axaml" />
    <AvaloniaXaml Remove="Views\**\*.axaml" />
    <AvaloniaXaml Remove="CompUI_RWS\PageType\InitCfgPage\SingleTrackStation\**\*.axaml" />
    <AvaloniaXaml Remove="CompUI_RWS\PageType\InitCfgPage\SingleControlSingleLimit\**\*.axaml" />
    <AvaloniaXaml Remove="CompUI_RWS\PageType\InitCfgPage\SingleControlDoubleLimit\**\*.axaml" />
    <AvaloniaXaml Remove="CompUI_RWS\PageType\InitCfgPage\DoubleControlSingleLimit\**\*.axaml" />
    <AvaloniaXaml Remove="CompUI_RWS\PageType\InitCfgPage\DoubleControlDoubleLimit\**\*.axaml" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Models\" />
    <AvaloniaResource Include="Assets\**" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="F:\RWS\RailWorkStationSubMachineModules\Module\RailWorkStationSubMachineModulesFactoryCfg.cs" Link="Module\RailWorkStationSubMachineModulesFactoryCfg.cs" />
    <Compile Include="F:\RWS\RailWorkStationSubMachineModules\Module\RailWorkStationSubMachineModulesInitCfg.cs" Link="Module\RailWorkStationSubMachineModulesInitCfg.cs" />
    <Compile Include="F:\RWS\RailWorkStationSubMachineModules\Module\RailWorkStationSubMachineModulesPPCfg.cs" Link="Module\RailWorkStationSubMachineModulesPPCfg.cs" />
    <Compile Include="F:\RWS\RailWorkStationSubMachineModules\Module\RailWorkStationSubMachineModulesParams.cs" Link="Module\RailWorkStationSubMachineModulesParams.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="CompUI_RWS\PageType\InitCfgPage\TrackStationConfig\Images\ctr-No.png" />
    <None Remove="CompUI_RWS\PageType\InitCfgPage\TrackStationConfig\Images\ctr-Station-active.png" />
    <None Remove="CompUI_RWS\PageType\InitCfgPage\TrackStationConfig\Images\ctr-Station.png" />
    <None Remove="CompUI_RWS\PageType\InitCfgPage\TrackStationConfig\Images\ctr-Yes.png" />
  </ItemGroup>
  <ItemGroup>
    <AvaloniaResource Include="CompUI_RWS\PageType\InitCfgPage\TrackStationConfig\Images\ctr-No.png" />
    <AvaloniaResource Include="CompUI_RWS\PageType\InitCfgPage\TrackStationConfig\Images\ctr-Station-active.png" />
    <AvaloniaResource Include="CompUI_RWS\PageType\InitCfgPage\TrackStationConfig\Images\ctr-Station.png" />
    <AvaloniaResource Include="CompUI_RWS\PageType\InitCfgPage\TrackStationConfig\Images\ctr-Yes.png" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Griffins.ImeIOT" Version="7.1.0" ExcludeAssets="runtime" />
    <PackageReference Include="Griffins.UI2" Version="7.1.0" ExcludeAssets="runtime" />
    <PackageReference Include="Griffins.Map2" Version="7.1.0" ExcludeAssets="runtime" />
    <PackageReference Include="Griffins.ImeIOT.Map" Version="7.1.0" ExcludeAssets="runtime" />
    <PackageReference Include="Griffins.Map.UI" Version="7.1.0" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.CSharp" Version="4.7.0" ExcludeAssets="runtime" />
    <PackageReference Include="Newtonsoft.JsonG" Version="7.1.0" ExcludeAssets="runtime" />
    <PackageReference Include="Avalonia" Version="11.3.3" ExcludeAssets="runtime" />
    <PackageReference Include="Avalonia.ReactiveUI" Version="11.3.3" ExcludeAssets="runtime" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\公共引用\GKG.UI\GKG.UI.csproj" />
    <ProjectReference Include="..\公共引用\GKG\GKG.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="RailWorkStationSubMachineModules">
      <HintPath>..\..\..\Griffins7.1\Bin\Share\ImeIOT\SubMM\RailWorkStationSubMachineModules.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Compile Update="ResourceA.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>ResourceA.resx</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="ResourceA.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>ResourceA.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>
</Project>
