<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Griffins.CompUI.RWS.CompUI_RWS.PageType.InitCfgPage.WorkStationInitConfig.ViewModels"
             xmlns:local="clr-namespace:Griffins.CompUI.RWS.CompUI_RWS.PageType.InitCfgPage.WorkStationInitConfig.Views"
             xmlns:custom="clr-namespace:GKG.UI;assembly=GKG.UI"
             xmlns:general="clr-namespace:GKG.UI.General;assembly=GKG.UI"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:DataType="vm:WorkStationInitConfigCompUIViewModel"
             x:Class="Griffins.CompUI.RWS.CompUI_RWS.PageType.InitCfgPage.WorkStationInitConfig.Views.WorkStationInitConfigCompUIView">
  <Design.DataContext>
    <vm:WorkStationInitConfigCompUIViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="dg|DataGrid.trans-speed-grid">
      <Setter Property="RowHeight" Value="44" />
      <Setter Property="ColumnHeaderHeight" Value="38" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#22000000" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
      <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
      <Setter Property="SelectionMode" Value="Single" />
    </Style>

    <Style Selector="dg|DataGrid.trans-speed-grid dg|DataGridColumnHeader">
      <Setter Property="Background" Value="#08000000" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="6,0" />
      <Setter Property="BorderBrush" Value="#22000000" />
      <Setter Property="BorderThickness" Value="0,0,1,1" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="dg|DataGrid.trans-speed-grid dg|DataGridCell">
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="BorderBrush" Value="#16000000" />
      <Setter Property="BorderThickness" Value="0,0,1,1" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="dg|DataGrid.trans-speed-grid NumericUpDown">
      <Setter Property="Width" Value="112" />
      <Setter Property="MaxWidth" Value="112" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="dg|DataGrid.trans-speed-grid dg|DataGridRow:selected">
      <Setter Property="Background" Value="#12007ACC" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="10" Orientation="Vertical" Spacing="16">

      <Border BorderBrush="#33000000" BorderThickness="1" CornerRadius="6" Padding="10">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
          <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="6">
            <TextBlock Text="工位预览" FontWeight="Bold" FontSize="13" />
            <Border CornerRadius="6" BorderThickness="1" BorderBrush="#33000000" Background="Transparent" Padding="0">
              <Grid ColumnDefinitions="1*,3*,1*" RowDefinitions="*" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Height="70" Width="240">
                <Image Grid.Column="0"
                       IsVisible="{Binding StationPreview.LeftSensorVisible}"
                       Source="{Binding StationPreview.LeftSensorImage}"
                       Margin="6,6"
                       Stretch="Uniform"
                       StretchDirection="Both"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"/>

                <Image Grid.Column="1"
                       Source="{Binding StationPreview.StationImage}"
                       Stretch="Uniform"
                       StretchDirection="Both"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"/>

                <Image Grid.Column="2"
                       IsVisible="{Binding StationPreview.RightSensorVisible}"
                       Source="{Binding StationPreview.RightSensorImage}"
                       Margin="6,6"
                       Stretch="Uniform"
                       StretchDirection="Both"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"/>
              </Grid>
            </Border>
          </StackPanel>

          <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="3" VerticalAlignment="Center">
            <TextBlock Text="轨道工位初始化配置" FontWeight="Bold" FontSize="18" />
            <TextBlock Text="电气参数与速度档位设置" FontWeight="SemiBold" />
            <TextBlock Text="用于设置挡板气缸初始化参数、感应器 ID 以及工位运输速度档位。" Foreground="#66000000" TextWrapping="Wrap" />
          </StackPanel>
        </Grid>
      </Border>

      <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="16" VerticalAlignment="Top">
        <Border Grid.Column="0"
                IsVisible="{Binding ShowBlockCylinderSection}"
                BorderBrush="#33000000"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                VerticalAlignment="Top">
          <StackPanel Orientation="Vertical" Spacing="12">
            <TextBlock Text="左右挡板气缸初始化参数" FontWeight="Bold" />

            <Border IsVisible="{Binding ShowLeftBlockCylinderConfig}"
                    BorderBrush="#22000000"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10">
              <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock Text="左挡板气缸初始化参数" FontWeight="SemiBold" />
                <Border IsEnabled="{Binding CanEditInitConfig}">
                  <general:CylinderConfigView DataContext="{Binding LeftCylinderConfigViewModel}" />
                </Border>
              </StackPanel>
            </Border>

            <Border IsVisible="{Binding ShowRightBlockCylinderConfig}"
                    BorderBrush="#22000000"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10">
              <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock Text="右挡板气缸初始化参数" FontWeight="SemiBold" />
                <Border IsEnabled="{Binding CanEditInitConfig}">
                  <general:CylinderConfigView DataContext="{Binding RightCylinderConfigViewModel}" />
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                IsVisible="{Binding ShowEleConfigSection}"
                BorderBrush="#33000000"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                VerticalAlignment="Top">
          <StackPanel Orientation="Vertical" Spacing="12">
            <TextBlock Text="左/右/接近感应器 ID" FontWeight="Bold" />

            <Border IsVisible="{Binding ShowLeftSensorConfig}"
                    BorderBrush="#22000000"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10">
              <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock Text="左感应器 ID" FontWeight="SemiBold" />
                <Border IsEnabled="{Binding CanEditInitConfig}">
                  <local:SensorConfigView DataContext="{Binding LeftSensorConfigViewModel}" />
                </Border>
              </StackPanel>
            </Border>

            <Border IsVisible="{Binding ShowRightSensorConfig}"
                    BorderBrush="#22000000"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10">
              <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock Text="右感应器 ID" FontWeight="SemiBold" />
                <Border IsEnabled="{Binding CanEditInitConfig}">
                  <local:SensorConfigView DataContext="{Binding RightSensorConfigViewModel}" />
                </Border>
              </StackPanel>
            </Border>

            <Border IsVisible="{Binding ShowProximitySensorConfig}"
                    BorderBrush="#22000000"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10">
              <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock Text="接近感应器 ID" FontWeight="SemiBold" />
                <Border IsEnabled="{Binding CanEditInitConfig}">
                  <local:SensorConfigView DataContext="{Binding ProximitySensorConfigViewModel}" />
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Grid.Column="2"
                Width="520"
                MaxWidth="520"
                HorizontalAlignment="Left"
                BorderBrush="#33000000"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                VerticalAlignment="Top"
                ClipToBounds="True">
          <StackPanel Orientation="Vertical" Spacing="8" VerticalAlignment="Top">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <TextBlock Grid.Column="0" Text="工位运输速度档位列表" FontWeight="Bold" VerticalAlignment="Center" TextWrapping="Wrap" />
              <Button Grid.Column="1" Content="新增" Command="{Binding AddTransSpeedGearCommand}" IsEnabled="{Binding CanEditTransSpeedGearList}" />
            </Grid>

            <dg:DataGrid Classes="trans-speed-grid"
                         ItemsSource="{Binding TransSpeedGearItems}"
                         AutoGenerateColumns="False"
                         CanUserResizeColumns="False"
                         CanUserReorderColumns="False"
                         CanUserSortColumns="False"
                         GridLinesVisibility="All"
                         HeadersVisibility="Column"
                         IsReadOnly="False"
                         Width="496"
                         MaxWidth="496"
                         Height="220"
                         VerticalAlignment="Top"
                         HorizontalAlignment="Stretch">
              <dg:DataGrid.Columns>
                <dg:DataGridTextColumn Header="序号"
                                       Binding="{Binding RowNumber}"
                                       IsReadOnly="True"
                                       Width="72"
                                       MinWidth="72"
                                       MaxWidth="72" />
                <dg:DataGridTextColumn Header="档位ID"
                                       Binding="{Binding RowNumber}"
                                       IsReadOnly="True"
                                       Width="128"
                                       MinWidth="128"
                                       MaxWidth="128" />
                <dg:DataGridTemplateColumn Header="运输速度" Width="168" MinWidth="168" MaxWidth="168">
                  <dg:DataGridTemplateColumn.CellTemplate>
                    <DataTemplate x:DataType="vm:WorkStationInitConfigCompUIViewModel+TransSpeedGearItemViewModel">
                      <TextBlock Text="{Binding SpeedText}"
                                 HorizontalAlignment="Center"
                                 TextAlignment="Center"
                                 VerticalAlignment="Center"
                                 Margin="2,0" />
                    </DataTemplate>
                  </dg:DataGridTemplateColumn.CellTemplate>
                  <dg:DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate x:DataType="vm:WorkStationInitConfigCompUIViewModel+TransSpeedGearItemViewModel">
                      <NumericUpDown Value="{Binding SpeedNumeric, Mode=TwoWay}"
                                     Minimum="0"
                                     Increment="0.1"
                                     FormatString="F3"
                                     MinHeight="32"
                                     HorizontalContentAlignment="Center"
                                     TextAlignment="Center"
                                     IsEnabled="{Binding CanEdit}" />
                    </DataTemplate>
                  </dg:DataGridTemplateColumn.CellEditingTemplate>
                </dg:DataGridTemplateColumn>
                <dg:DataGridTemplateColumn Header="操作" Width="112" MinWidth="112" MaxWidth="112">
                  <dg:DataGridTemplateColumn.CellTemplate>
                    <DataTemplate x:DataType="vm:WorkStationInitConfigCompUIViewModel+TransSpeedGearItemViewModel">
                      <Button Content="删除"
                              HorizontalAlignment="Center"
                              MinWidth="44"
                              MinHeight="28"
                              Padding="10,0"
                              Command="{Binding RemoveCommand}"
                              IsEnabled="{Binding CanEdit}" />
                    </DataTemplate>
                  </dg:DataGridTemplateColumn.CellTemplate>
                </dg:DataGridTemplateColumn>
              </dg:DataGrid.Columns>
            </dg:DataGrid>
          </StackPanel>
        </Border>
      </Grid>

    </StackPanel>
  </ScrollViewer>
</UserControl>
