<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Griffins.CompUI.PushRod.CompUI_PushRod.PageType.RecipeCfgPage.MotorPushRodRecipe.ViewModels"
             xmlns:custom="clr-namespace:GKG.UI;assembly=GKG.UI"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="460"
             x:DataType="vm:MotorPushRodRecipeCompUIViewModel"
             x:Class="Griffins.CompUI.PushRod.CompUI_PushRod.PageType.RecipeCfgPage.MotorPushRodRecipe.Views.MotorPushRodRecipeCompUIView"
             Tag="{Binding ViewTag, Mode=TwoWay}">
  <UserControl.Styles>
    <Style Selector="Border.PageShell">
      <Setter Property="Background" Value="#F1F4F8"/>
      <Setter Property="Padding" Value="18"/>
    </Style>
    <Style Selector="Border.Card">
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#E0E3E9"/>
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="BoxShadow" Value="0 4 12 0 #120F172A"/>
    </Style>
    <Style Selector="Border.ContentPanel">
      <Setter Property="Background" Value="#F7FAFD"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="BorderBrush" Value="#E8EAEE"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="14,16"/>
    </Style>
    <Style Selector="TextBlock.SectionTitle">
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="Foreground" Value="#1F3F75"/>
    </Style>
    <Style Selector="TextBlock.FormLabel">
      <Setter Property="Foreground" Value="#3C4652"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="Button.PrimaryAction">
      <Setter Property="Background" Value="#1C5ED6"/>
      <Setter Property="Foreground" Value="#FFF"/>
      <Setter Property="BorderBrush" Value="#1C5ED6"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="MinWidth" Value="108"/>
      <Setter Property="Height" Value="36"/>
    </Style>
    <Style Selector="custom|TextInputControl">
      <Setter Property="FixWidth" Value="False"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
  </UserControl.Styles>

  <Border Classes="PageShell">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <Border Classes="Card">
        <Grid RowDefinitions="Auto,16,Auto">
          <TextBlock Classes="SectionTitle" Text="电机推杆配方配置"/>
          <Border Grid.Row="2" Classes="ContentPanel">
            <Grid ColumnDefinitions="152,120,152,120,*"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="16"
                  RowSpacing="16">
              <TextBlock Grid.Row="0" Grid.Column="0" Classes="FormLabel" Text="当前位置"/>
              <custom:TextInputControl Grid.Row="0"
                                       Grid.Column="1"
                                       ViewModel="{Binding CurrentValueViewModel}"
                                       LabelName=""
                                       WidthLevel="Small3"/>
              <TextBlock Grid.Row="0" Grid.Column="2" Classes="FormLabel" Text="推料位置"/>
              <custom:TextInputControl Grid.Row="0"
                                       Grid.Column="3"
                                       ViewModel="{Binding PushDistanceViewModel}"
                                       LabelName=""
                                       WidthLevel="Small3"/>

              <TextBlock Grid.Row="1" Grid.Column="0" Classes="FormLabel" Text="推杆轴速度"/>
              <custom:TextInputControl Grid.Row="1"
                                       Grid.Column="1"
                                       ViewModel="{Binding PushAxisSpeedViewModel}"
                                       LabelName=""
                                       WidthLevel="Small3"/>
              <TextBlock Grid.Row="1" Grid.Column="2" Classes="FormLabel" Text="推杆轴加速度"/>
              <custom:TextInputControl Grid.Row="1"
                                       Grid.Column="3"
                                       ViewModel="{Binding PushAxisAccelerationViewModel}"
                                       LabelName=""
                                       WidthLevel="Small3"/>

              <Grid Grid.Row="0"
                    Grid.Column="4"
                    Grid.RowSpan="2"
                    ColumnDefinitions="Auto,Auto,Auto"
                    RowDefinitions="Auto"
                    ColumnSpacing="12"
                    RowSpacing="12"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top">
                <Button Grid.Row="0" Grid.Column="0" Classes="PrimaryAction" Content="推料一次" Command="{Binding PushOnceCommand}"/>
                <Button Grid.Row="0" Grid.Column="1" Classes="PrimaryAction" Content="推杆伸出" Command="{Binding PushRodForwardCommand}"/>
                <Button Grid.Row="0" Grid.Column="2" Classes="PrimaryAction" Content="推杆缩回" Command="{Binding PushRodBackwardCommand}"/>
              </Grid>
            </Grid>
          </Border>
        </Grid>
      </Border>
    </ScrollViewer>
  </Border>
</UserControl>
