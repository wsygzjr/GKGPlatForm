      <ExcludeAssets>runtime</ExcludeAssets>
    </ProjectReference>
    <ProjectReference Include="..\公共引用\GKG.UI\GKG.UI.csproj">
      <Private>False</Private>
      <ExcludeAssets>runtime</ExcludeAssets>
