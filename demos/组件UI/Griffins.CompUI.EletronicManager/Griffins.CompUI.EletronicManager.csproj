			<PdbsToDelete Include="$(OutputPath)WeighingBalanceSubMachineModules.pdb" />



			<!-- 要删除的 XML 文件 -->

			<DllsToDelete Include="$(OutputPath)GKG.xml" />
			<XmlsToDelete Include="$(OutputPath)GKG.UI.xml" />
			<XmlsToDelete Include="$(OutputPath)AvaloniaVisionControl.xml" />



			<!-- 合并所有要删除的文件 -->

			<AllFilesToDelete Include="@(DllsToDelete)" />
			<AllFilesToDelete Include="@(PdbsToDelete)" />
			<AllFilesToDelete Include="@(XmlsToDelete)" />
		</ItemGroup>

		<!-- 删除文件 -->

		<Delete Files="@(AllFilesToDelete)" ContinueOnError="true" />
	</Target>
</Project>
