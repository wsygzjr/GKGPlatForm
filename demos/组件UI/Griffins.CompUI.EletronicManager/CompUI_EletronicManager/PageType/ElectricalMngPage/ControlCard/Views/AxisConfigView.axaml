<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:custom="clr-namespace:GKG.UI;assembly=GKG.UI"
             xmlns:views="clr-namespace:Griffins.CompUI.EletronicManager.CompUI_EletronicManager.PageType.ElectricalMngPage.ControlCard.Views"
             xmlns:vm="clr-namespace:Griffins.CompUI.EletronicManager.CompUI_EletronicManager.PageType.ElectricalMngPage.ControlCard.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="620"
             d:DesignHeight="760"
             x:DataType="vm:AxisConfigViewModel"
             x:Class="Griffins.CompUI.EletronicManager.CompUI_EletronicManager.PageType.ElectricalMngPage.ControlCard.Views.AxisConfigView">

    <UserControl.Styles>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#20407B" />
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E0E3E9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style Selector="Border.title-panel">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E0E3E9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,12" />
        </Style>
        <Style Selector="Button.toolbar-primary">
            <Setter Property="Background" Value="#1C5ED6" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#1C5ED6" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.toolbar-danger">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#FF3D3D" />
            <Setter Property="BorderBrush" Value="#FF3D3D" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.action-danger">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#FF3D3D" />
            <Setter Property="BorderBrush" Value="#FF3D3D" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F4F8" />
            <Setter Property="Foreground" Value="#5C5F63" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="#E0E3E9" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="BorderBrush" Value="#E8EAEE" />
        </Style>
        <Style Selector="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#111111" />
        </Style>
        <Style Selector="DataGridRow:selected">
            <Setter Property="Background" Value="#F2F7FF" />
            <Setter Property="Foreground" Value="#1C5ED6" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E0E3E9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style Selector="Button.advanced-btn:disabled">
            <Setter Property="Background" Value="#D5DDE3" />
            <Setter Property="BorderBrush" Value="#B8C4CC" />
            <Setter Property="Foreground" Value="#7A8A95" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>
        <Style Selector="Button.advanced-btn">
            <Setter Property="Background" Value="#1C5ED6" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#1C5ED6" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Styles>

    <Border Classes="panel">
        <Grid ColumnDefinitions="770,*"
              ColumnSpacing="12">
            <Grid Grid.Column="0"
                  RowDefinitions="Auto,*"
                  RowSpacing="10">
                <DockPanel Grid.Row="0" LastChildFill="False">
                    <Button DockPanel.Dock="Left"
                            Classes="toolbar-primary"
                            Content="新增"
                            MinWidth="88"
                            Height="36"
                            Command="{Binding AddCommand}" />
                    <Button DockPanel.Dock="Left"
                            Classes="toolbar-danger"
                            Margin="8,0,0,0"
                            Content="删除"
                            MinWidth="88"
                            Height="36"
                            Command="{Binding DeleteCheckedCommand}" />
                </DockPanel>

                <DataGrid Grid.Row="1"
                          Name="AxisConfigDataGrid"
                          ItemsSource="{Binding AxisItems}"
                          SelectedItem="{Binding SelectedAxisItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          Background="#FFFFFF"
                          BorderBrush="#E0E3E9"
                          BorderThickness="1"
                          GridLinesVisibility="All"
                          HeadersVisibility="Column"
                          RowHeight="40">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="80"
                                                CanUserSort="False">
                            <DataGridTemplateColumn.Header>
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          ToolTip.Tip="全选"
                                          IsChecked="{Binding DataContext.IsAllChecked, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="序号"
                                            Binding="{Binding SequenceNo, Mode=OneWay}"
                                            IsReadOnly="True"
                                            Width="70" />

                        <DataGridTextColumn Header="逻辑轴名"
                                            Binding="{Binding AxisNameEditor, Mode=TwoWay}"
                                            Width="145" />

                        <DataGridTemplateColumn Header="运控卡"
                                                Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding ControlCardComboxViewModel.ItemsSource}"
                                              SelectedItem="{Binding ControlCardComboxViewModel.SelectedItem, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="轴号"
                                                Width="105">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding AxisComboxViewModel.ItemsSource}"
                                              SelectedItem="{Binding AxisComboxViewModel.SelectedItem, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="绑定模组"
                                            Binding="{Binding BindingModuleDisplay, Mode=OneWay}"
                                            IsReadOnly="True"
                                            Width="100" />

                        <DataGridTemplateColumn Header="操作"
                                                Width="90"
                                                IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="删除"
                                            Classes="action-danger"
                                            HorizontalAlignment="Center"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Border Grid.Column="1"
                    BorderBrush="#E0E3E9"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#FFFFFF"
                    Padding="12">
                <Border Classes="panel">
                    <Grid RowDefinitions="Auto,*,Auto"
                          RowSpacing="12">
                        <Border Grid.Row="0"
                                Classes="title-panel">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{Binding SelectedItemDisplayName}"
                                       Classes="section-title" />
                        </Border>

                        <ContentControl Grid.Row="1"
                                        Name="AxisEditorHost" />

                        <Button Grid.Row="2"
                                HorizontalAlignment="Right"
                                MinWidth="140"
                                Height="34"
                                Content="轴驱动高级参数"
                                Classes="advanced-btn"
                                IsEnabled="{Binding CanOpenAdvancedParameter}"
                                Click="OpenAxisAdvancedParameterWindow_Click" />
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Border>
</UserControl>
