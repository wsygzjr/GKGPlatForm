<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Griffins.CompUI.EletronicManager.CompUI_EletronicManager.PageType.DebugPage.ViewModels"
        mc:Ignorable="d"
        x:DataType="vm:AxisDebugWindowViewModel"
        x:Class="Griffins.CompUI.EletronicManager.CompUI_EletronicManager.PageType.DebugPage.Views.AxisDebugIOInView">

  <UserControl.Styles>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#E0E3E9" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="Button.axis-action">
      <Setter Property="Background" Value="#1C5ED6" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#1C5ED6" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="12,6" />
    </Style>
    <Style Selector="Button.axis-action:disabled">
      <Setter Property="Background" Value="#D5DDE3" />
      <Setter Property="Foreground" Value="#7A8A95" />
      <Setter Property="BorderBrush" Value="#B8C4CC" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ToggleButton.io-toggle">
      <Setter Property="MinWidth" Value="28" />
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="Background" Value="#BDBDBD" />
      <Setter Property="BorderBrush" Value="#9E9E9E" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Template">
        <ControlTemplate>
          <Grid>
            <Border Width="16"
                    Height="16"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ToggleButton.io-toggle:checked">
      <Setter Property="Background" Value="#2ECC71" />
      <Setter Property="BorderBrush" Value="#27AE60" />
    </Style>
    <Style Selector="ToggleButton.io-toggle:disabled">
      <Setter Property="Opacity" Value="0.4" />
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="#334155" />
    </Style>
  </UserControl.Styles>

  <Border Background="#F1F4F8" Padding="10">
    <Grid ColumnDefinitions="Auto,Auto,Auto,*"
          ColumnSpacing="12">
      <Border Grid.Column="0"
              Width="360"
              Classes="panel">
        <Grid RowDefinitions="Auto,*">
          <Border Background="#F1F4F8"
                  BorderBrush="#E0E3E9"
                  BorderThickness="0,0,0,1"
                  Padding="0">
            <Grid ColumnDefinitions="180,180">
              <Border Background="#F1F4F8" />
              <Border Grid.Column="1"
                      Background="#F1F4F8"
                      BorderBrush="#E0E3E9"
                      BorderThickness="1,0,0,0" />
              <TextBlock Text="状态量名称"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         Margin="8,8"
                         FontWeight="Bold"
                         Foreground="#333333" />
              <TextBlock Grid.Column="1"
                         Text="开关"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         FontWeight="Bold"
                         Foreground="#333333" />
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding CommonSensors}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="#E8EAEE"
                          BorderThickness="0,0,0,1"
                          Padding="0"
                          Background="Transparent">
                    <Grid ColumnDefinitions="180,180"
                          MinHeight="34">
                      <Border Background="#F8FBFF" />
                      <Border Grid.Column="1"
                              Background="White"
                              BorderBrush="#E8EAEE"
                              BorderThickness="1,0,0,0" />
                      <TextBlock Text="{Binding Name}"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 Margin="8,6"
                                 Foreground="#333333" />
                      <ToggleButton Grid.Column="1"
                                    Classes="io-toggle"
                                    IsChecked="{Binding IsOn, Mode=TwoWay}"
                                    IsEnabled="{Binding CanWrite}"
                                    VerticalAlignment="Stretch"
                                    HorizontalAlignment="Stretch" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Width="360"
              Classes="panel">
        <Grid RowDefinitions="Auto,*">
          <Border Background="#F1F4F8"
                  BorderBrush="#E0E3E9"
                  BorderThickness="0,0,0,1"
                  Padding="0">
            <Grid ColumnDefinitions="180,180">
              <Border Background="#F1F4F8" />
              <Border Grid.Column="1"
                      Background="#F1F4F8"
                      BorderBrush="#E0E3E9"
                      BorderThickness="1,0,0,0" />
              <TextBlock Text="状态量名称"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         Margin="8,8"
                         FontWeight="Bold"
                         Foreground="#333333" />
              <TextBlock Grid.Column="1"
                         Text="开关"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         FontWeight="Bold"
                         Foreground="#333333" />
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding TrackASensors}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="#E8EAEE"
                          BorderThickness="0,0,0,1"
                          Padding="0"
                          Background="Transparent">
                    <Grid ColumnDefinitions="180,180"
                          MinHeight="34">
                      <Border Background="#F8FBFF" />
                      <Border Grid.Column="1"
                              Background="White"
                              BorderBrush="#E8EAEE"
                              BorderThickness="1,0,0,0" />
                      <TextBlock Text="{Binding Name}"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 Margin="8,6"
                                 Foreground="#333333" />
                      <ToggleButton Grid.Column="1"
                                    Classes="io-toggle"
                                    IsChecked="{Binding IsOn, Mode=TwoWay}"
                                    IsEnabled="{Binding CanWrite}"
                                    VerticalAlignment="Stretch"
                                    HorizontalAlignment="Stretch" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <Border Grid.Column="2"
              Width="360"
              Classes="panel">
        <Grid RowDefinitions="Auto,*">
          <Border Background="#F1F4F8"
                  BorderBrush="#E0E3E9"
                  BorderThickness="0,0,0,1"
                  Padding="0">
            <Grid ColumnDefinitions="180,180">
              <Border Background="#F1F4F8" />
              <Border Grid.Column="1"
                      Background="#F1F4F8"
                      BorderBrush="#E0E3E9"
                      BorderThickness="1,0,0,0" />
              <TextBlock Text="状态量名称"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         Margin="8,8"
                         FontWeight="Bold"
                         Foreground="#333333" />
              <TextBlock Grid.Column="1"
                         Text="开关"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         FontWeight="Bold"
                         Foreground="#333333" />
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding TrackBSensors}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="#E8EAEE"
                          BorderThickness="0,0,0,1"
                          Padding="0"
                          Background="Transparent">
                    <Grid ColumnDefinitions="180,180"
                          MinHeight="34">
                      <Border Background="#F8FBFF" />
                      <Border Grid.Column="1"
                              Background="White"
                              BorderBrush="#E8EAEE"
                              BorderThickness="1,0,0,0" />
                      <TextBlock Text="{Binding Name}"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 Margin="8,6"
                                 Foreground="#333333" />
                      <ToggleButton Grid.Column="1"
                                    Classes="io-toggle"
                                    IsChecked="{Binding IsOn, Mode=TwoWay}"
                                    IsEnabled="{Binding CanWrite}"
                                    VerticalAlignment="Stretch"
                                    HorizontalAlignment="Stretch" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>

