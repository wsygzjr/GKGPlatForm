<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Griffins.CompUI.Rail.CompUI_Rail.PageType.RecipeCfgPage.RailRecipe.ViewModels"
             xmlns:custom="clr-namespace:GKG.UI;assembly=GKG.UI"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="420"
             x:DataType="vm:RailRecipeCompUIViewModel"
             x:Class="Griffins.CompUI.Rail.CompUI_Rail.PageType.RecipeCfgPage.RailRecipe.Views.RailRecipeCompUIView"
             Tag="{Binding ViewTag, Mode=TwoWay}">
  <UserControl.Styles>
    <Style Selector="Border.PageShell">
      <Setter Property="Background" Value="#F1F4F8"/>
      <Setter Property="Padding" Value="18"/>
    </Style>
    <Style Selector="Border.Card">
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#E0E3E9"/>
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="BoxShadow" Value="0 4 12 0 #120F172A"/>
    </Style>
    <Style Selector="Border.ContentPanel">
      <Setter Property="Background" Value="#F7FAFD"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="BorderBrush" Value="#E8EAEE"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="14,16"/>
    </Style>
    <Style Selector="TextBlock.FormLabel">
      <Setter Property="Foreground" Value="#3C4652"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="TextBlock.SectionTitle">
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="Foreground" Value="#1F3F75"/>
    </Style>
    <Style Selector="custom|ComboxControl">
      <Setter Property="FixWidth" Value="False"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="custom|TextInputControl">
      <Setter Property="FixWidth" Value="False"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
  </UserControl.Styles>

  <Border Classes="PageShell">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <Border Classes="Card">
        <Grid RowDefinitions="Auto,16,Auto">
          <TextBlock Classes="SectionTitle" Text="单层轨道配方配置"/>
          <Border Grid.Row="2" Classes="ContentPanel">
            <Grid ColumnDefinitions="160,220,160,220"
                  RowDefinitions="Auto,16,Auto,16,Auto"
                  ColumnSpacing="16"
                  RowSpacing="16">
              <TextBlock Grid.Row="0" Grid.Column="0" Classes="FormLabel" Text="轨道工作模式"/>
              <custom:ComboxControl Grid.Row="0"
                                    Grid.Column="1"
                                    ViewModel="{Binding TransferDirectionViewModel}"
                                    LabelName=""
                                    WidthLevel="Small3"/>
              <TextBlock Grid.Row="0" Grid.Column="2" Classes="FormLabel" Text="进板目标位"/>
              <custom:ComboxControl Grid.Row="0"
                                    Grid.Column="3"
                                    ViewModel="{Binding InletPanelWorkStationViewModel}"
                                    LabelName=""
                                    WidthLevel="Small3"/>

              <TextBlock Grid.Row="2" Grid.Column="0" Classes="FormLabel" Text="出板目标位"/>
              <custom:ComboxControl Grid.Row="2"
                                    Grid.Column="1"
                                    ViewModel="{Binding OutletPanelWorkStationViewModel}"
                                    LabelName=""
                                    WidthLevel="Small3"/>
              <TextBlock Grid.Row="2" Grid.Column="2" Classes="FormLabel" Text="出板延时(ms)"/>
              <custom:TextInputControl Grid.Row="2"
                                       Grid.Column="3"
                                       ViewModel="{Binding OutletPanelDelayTimeViewModel}"
                                       LabelName=""
                                       WidthLevel="Small3"/>
            </Grid>
          </Border>
        </Grid>
      </Border>
    </ScrollViewer>
  </Border>
</UserControl>
