<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Griffins.CompUI.DispensingFunctionHead.CompUI_DispensingFunctionHead.PageType.FactoryCfgPage.DispensingFunctionHeadFactory.ViewModels"
             xmlns:custom="clr-namespace:GKG.UI;assembly=GKG.UI"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="360"
             x:DataType="vm:DispensingFunctionHeadFactoryCompUIViewModel"
             x:Class="Griffins.CompUI.DispensingFunctionHead.CompUI_DispensingFunctionHead.PageType.FactoryCfgPage.DispensingFunctionHeadFactory.Views.DispensingFunctionHeadFactoryCompUIView"
             Tag="{Binding ViewTag, Mode=TwoWay}">
  <UserControl.Styles>
    <Style Selector="Border.PageShell">
      <Setter Property="Background" Value="#F1F4F8"/>
      <Setter Property="Padding" Value="18"/>
    </Style>
    <Style Selector="Border.Card">
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#E0E3E9"/>
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="BoxShadow" Value="0 4 12 0 #120F172A"/>
    </Style>
    <Style Selector="Border.ContentPanel">
      <Setter Property="Background" Value="#F7FAFD"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="BorderBrush" Value="#E8EAEE"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="14,16"/>
    </Style>
    <Style Selector="TextBlock.FormLabel">
      <Setter Property="Foreground" Value="#3C4652"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="TextBlock.SectionTitle">
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="Foreground" Value="#1F3F75"/>
    </Style>
    <Style Selector="TextBlock.SectionHint">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="#6B7280"/>
      <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>
    <Style Selector="custom|ComboxControl">
      <Setter Property="FixWidth" Value="False"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
  </UserControl.Styles>

  <Border Classes="PageShell">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <Border Classes="Card">
        <Grid RowDefinitions="Auto,8,Auto,16,Auto">
          <TextBlock Classes="SectionTitle" Text="点胶机功能头出厂配置"/>
          <TextBlock Grid.Row="1" Classes="SectionHint" Text="配置点胶阀类型和供胶装置类型"/>
          
          <Border Grid.Row="2" Classes="ContentPanel" Margin="0,8,0,0">
            <Grid ColumnDefinitions="160,280,160,280"
                  RowDefinitions="Auto"
                  ColumnSpacing="16"
                  RowSpacing="16">
              <TextBlock Grid.Row="0" Grid.Column="0" Classes="FormLabel" Text="阀类型"/>
              <custom:ComboxControl Grid.Row="0"
                                    Grid.Column="1"
                                    ViewModel="{Binding ValveTypeViewModel}"
                                    LabelName=""
                                    WidthLevel="Small3"/>

              <TextBlock Grid.Row="0" Grid.Column="2" Classes="FormLabel" Text="供胶装置类型"/>
              <custom:ComboxControl Grid.Row="0"
                                    Grid.Column="3"
                                    ViewModel="{Binding GlueDispensingDeviceTypeViewModel}"
                                    LabelName=""
                                    WidthLevel="Small3"/>
            </Grid>
          </Border>
        </Grid>
      </Border>
    </ScrollViewer>
  </Border>
</UserControl>
