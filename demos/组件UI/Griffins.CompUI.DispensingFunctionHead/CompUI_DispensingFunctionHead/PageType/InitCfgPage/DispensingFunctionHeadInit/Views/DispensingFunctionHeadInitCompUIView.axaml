<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Griffins.CompUI.DispensingFunctionHead.CompUI_DispensingFunctionHead.PageType.InitCfgPage.DispensingFunctionHeadInit.ViewModels"
             xmlns:custom="clr-namespace:GKG.UI;assembly=GKG.UI"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:DataType="vm:DispensingFunctionHeadInitCompUIViewModel"
             x:Class="Griffins.CompUI.DispensingFunctionHead.CompUI_DispensingFunctionHead.PageType.InitCfgPage.DispensingFunctionHeadInit.Views.DispensingFunctionHeadInitCompUIView"
             Tag="{Binding ViewTag, Mode=TwoWay}">
  <UserControl.Styles>
    <Style Selector="Border.PageShell">
      <Setter Property="Background" Value="#F1F4F8"/>
      <Setter Property="Padding" Value="18"/>
    </Style>
    <Style Selector="Border.Card">
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#E0E3E9"/>
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="BoxShadow" Value="0 4 12 0 #120F172A"/>
    </Style>
    <Style Selector="Border.ContentPanel">
      <Setter Property="Background" Value="#F7FAFD"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="BorderBrush" Value="#E8EAEE"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="14,16"/>
    </Style>
    <Style Selector="TextBlock.FormLabel">
      <Setter Property="Foreground" Value="#3C4652"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="TextBlock.SectionTitle">
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="Foreground" Value="#1F3F75"/>
    </Style>
    <Style Selector="custom|ComboxControl">
      <Setter Property="FixWidth" Value="False"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="custom|TextInputControl">
      <Setter Property="FixWidth" Value="False"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="custom|ToggleSwitchControl">
      <Setter Property="FixWidth" Value="False"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
  </UserControl.Styles>

  <Border Classes="PageShell">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="16">
        
        <!-- Valve Parameters Section -->
        <Border Classes="Card">
          <Grid RowDefinitions="Auto,16,Auto">
            <TextBlock Classes="SectionTitle" Text="阀参数配置"/>
            <Border Grid.Row="2" Classes="ContentPanel">
              <Grid ColumnDefinitions="140,220,140,220,140,220"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                    ColumnSpacing="16"
                    RowSpacing="16">
                
                <TextBlock Grid.Row="0" Grid.Column="0" Classes="FormLabel" Text="绑定轴"/>
                <custom:ComboxControl Grid.Row="0"
                                      Grid.Column="1"
                                      ViewModel="{Binding XAxisBindingViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="0" Grid.Column="2" Classes="FormLabel" Text="阀名称"/>
                <custom:TextInputControl Grid.Row="0"
                                         Grid.Column="3"
                                         ViewModel="{Binding ValveNameViewModel}"
                                         LabelName=""
                                         WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="0" Grid.Column="4" Classes="FormLabel" Text="阀ID"/>
                <custom:TextInputControl Grid.Row="0"
                                         Grid.Column="5"
                                         ViewModel="{Binding ValveIDViewModel}"
                                         LabelName=""
                                         WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Classes="FormLabel" Text="阀报警IO"/>
                <custom:ComboxControl Grid.Row="1"
                                      Grid.Column="1"
                                      ViewModel="{Binding ValveAlarmIOViewModel.IOChannelViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="1" Grid.Column="2" Classes="FormLabel" Text="触发通道"/>
                <custom:TextInputControl Grid.Row="1"
                                         Grid.Column="3"
                                         ViewModel="{Binding ChannelViewModel}"
                                         LabelName=""
                                         WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="1" Grid.Column="4" Classes="FormLabel" Text="开阀时间(ms)"/>
                <custom:TextInputControl Grid.Row="1"
                                         Grid.Column="5"
                                         ViewModel="{Binding OpenValveTimeMsViewModel}"
                                         LabelName=""
                                         WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Classes="FormLabel" Text="关阀时间(ms)"/>
                <custom:TextInputControl Grid.Row="2"
                                         Grid.Column="1"
                                         ViewModel="{Binding CloseValveTimeMsViewModel}"
                                         LabelName=""
                                         WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="2" Grid.Column="2" Classes="FormLabel" Text="报警次数检测"/>
                <custom:TextInputControl Grid.Row="2"
                                         Grid.Column="3"
                                         ViewModel="{Binding AlarmCountDetectViewModel}"
                                         LabelName=""
                                         WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="2" Grid.Column="4" Classes="FormLabel" Text="是否检测报警次数"/>
                <custom:ToggleSwitchControl Grid.Row="2"
                                            Grid.Column="5"
                                            ViewModel="{Binding IsDetectAlarmCountViewModel}"
                                            LabelName=""
                                            WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="3" Grid.Column="0" Classes="FormLabel" Text="清洗间隔时间(s)"/>
                <custom:TextInputControl Grid.Row="3"
                                         Grid.Column="1"
                                         ViewModel="{Binding ManualCleaningNozzleTimeSViewModel}"
                                         LabelName=""
                                         WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="3" Grid.Column="2" Classes="FormLabel" Text="是否人工清洗"/>
                <custom:ToggleSwitchControl Grid.Row="3"
                                            Grid.Column="3"
                                            ViewModel="{Binding IsManualCleaningViewModel}"
                                            LabelName=""
                                            WidthLevel="Small3"/>
              </Grid>
            </Border>
          </Grid>
        </Border>

        <!-- Valve Communicator Parameters Section -->
        <Border Classes="Card">
          <Grid RowDefinitions="Auto,16,Auto">
            <TextBlock Classes="SectionTitle" Text="阀通讯参数配置"/>
            <Border Grid.Row="2" Classes="ContentPanel">
              <Grid ColumnDefinitions="140,220,140,220,140,220"
                    RowDefinitions="Auto,Auto,Auto,Auto"
                    ColumnSpacing="16"
                    RowSpacing="16">
                
                <TextBlock Grid.Row="0" Grid.Column="0" Classes="FormLabel" Text="串口号"/>
                <custom:ComboxControl Grid.Row="0"
                                      Grid.Column="1"
                                      ViewModel="{Binding ValveCommunicatorViewModel.PortNameViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="0" Grid.Column="2" Classes="FormLabel" Text="波特率"/>
                <custom:ComboxControl Grid.Row="0"
                                      Grid.Column="3"
                                      ViewModel="{Binding ValveCommunicatorViewModel.BaudRateViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="0" Grid.Column="4" Classes="FormLabel" Text="数据位"/>
                <custom:ComboxControl Grid.Row="0"
                                      Grid.Column="5"
                                      ViewModel="{Binding ValveCommunicatorViewModel.DataBitsViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Classes="FormLabel" Text="停止位"/>
                <custom:ComboxControl Grid.Row="1"
                                      Grid.Column="1"
                                      ViewModel="{Binding ValveCommunicatorViewModel.StopBitsViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="1" Grid.Column="2" Classes="FormLabel" Text="校验位"/>
                <custom:ComboxControl Grid.Row="1"
                                      Grid.Column="3"
                                      ViewModel="{Binding ValveCommunicatorViewModel.ParityViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="1" Grid.Column="4" Classes="FormLabel" Text="Modbus类型"/>
                <custom:ComboxControl Grid.Row="1"
                                      Grid.Column="5"
                                      ViewModel="{Binding ValveCommunicatorViewModel.ModbusTypeViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Classes="FormLabel" Text="启用CRC16"/>
                <custom:ToggleSwitchControl Grid.Row="2"
                                            Grid.Column="1"
                                            ViewModel="{Binding ValveCommunicatorViewModel.EnableCRC16ViewModel}"
                                            LabelName=""
                                            WidthLevel="Small3"/>
              </Grid>
            </Border>
          </Grid>
        </Border>

        <!-- Valve Pressure Control Parameters Section -->
        <Border Classes="Card">
          <Grid RowDefinitions="Auto,16,Auto">
            <TextBlock Classes="SectionTitle" Text="阀气压控制参数配置"/>
            <Border Grid.Row="2" Classes="ContentPanel">
              <Grid ColumnDefinitions="140,220,140,220,140,220"
                    RowDefinitions="Auto,Auto,Auto,Auto"
                    ColumnSpacing="16"
                    RowSpacing="16">
                
                <TextBlock Grid.Row="0" Grid.Column="0" Classes="FormLabel" Text="串口号"/>
                <custom:ComboxControl Grid.Row="0"
                                      Grid.Column="1"
                                      ViewModel="{Binding ValvePressureControlViewModel.PortNameViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="0" Grid.Column="2" Classes="FormLabel" Text="波特率"/>
                <custom:ComboxControl Grid.Row="0"
                                      Grid.Column="3"
                                      ViewModel="{Binding ValvePressureControlViewModel.BaudRateViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="0" Grid.Column="4" Classes="FormLabel" Text="数据位"/>
                <custom:ComboxControl Grid.Row="0"
                                      Grid.Column="5"
                                      ViewModel="{Binding ValvePressureControlViewModel.DataBitsViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Classes="FormLabel" Text="停止位"/>
                <custom:ComboxControl Grid.Row="1"
                                      Grid.Column="1"
                                      ViewModel="{Binding ValvePressureControlViewModel.StopBitsViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="1" Grid.Column="2" Classes="FormLabel" Text="校验位"/>
                <custom:ComboxControl Grid.Row="1"
                                      Grid.Column="3"
                                      ViewModel="{Binding ValvePressureControlViewModel.ParityViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="1" Grid.Column="4" Classes="FormLabel" Text="Modbus类型"/>
                <custom:ComboxControl Grid.Row="1"
                                      Grid.Column="5"
                                      ViewModel="{Binding ValvePressureControlViewModel.ModbusTypeViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Classes="FormLabel" Text="启用CRC16"/>
                <custom:ToggleSwitchControl Grid.Row="2"
                                            Grid.Column="1"
                                            ViewModel="{Binding ValvePressureControlViewModel.EnableCRC16ViewModel}"
                                            LabelName=""
                                            WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="2" Grid.Column="2" Classes="FormLabel" Text="站号"/>
                <custom:TextInputControl Grid.Row="2"
                                         Grid.Column="3"
                                         ViewModel="{Binding ValvePressureStationIdViewModel}"
                                         LabelName=""
                                         WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="2" Grid.Column="4" Classes="FormLabel" Text="通道号"/>
                <custom:TextInputControl Grid.Row="2"
                                         Grid.Column="5"
                                         ViewModel="{Binding ValvePressureChannelIdViewModel}"
                                         LabelName=""
                                         WidthLevel="Small3"/>
              </Grid>
            </Border>
          </Grid>
        </Border>

        <!-- Glue Dispensing Device Pressure Control Parameters Section -->
        <Border Classes="Card">
          <Grid RowDefinitions="Auto,16,Auto">
            <TextBlock Classes="SectionTitle" Text="供胶装置气压控制参数配置"/>
            <Border Grid.Row="2" Classes="ContentPanel">
              <Grid ColumnDefinitions="140,220,140,220,140,220"
                    RowDefinitions="Auto,Auto,Auto,Auto"
                    ColumnSpacing="16"
                    RowSpacing="16">
                
                <TextBlock Grid.Row="0" Grid.Column="0" Classes="FormLabel" Text="串口号"/>
                <custom:ComboxControl Grid.Row="0"
                                      Grid.Column="1"
                                      ViewModel="{Binding GluePressureControlViewModel.PortNameViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="0" Grid.Column="2" Classes="FormLabel" Text="波特率"/>
                <custom:ComboxControl Grid.Row="0"
                                      Grid.Column="3"
                                      ViewModel="{Binding GluePressureControlViewModel.BaudRateViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="0" Grid.Column="4" Classes="FormLabel" Text="数据位"/>
                <custom:ComboxControl Grid.Row="0"
                                      Grid.Column="5"
                                      ViewModel="{Binding GluePressureControlViewModel.DataBitsViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Classes="FormLabel" Text="停止位"/>
                <custom:ComboxControl Grid.Row="1"
                                      Grid.Column="1"
                                      ViewModel="{Binding GluePressureControlViewModel.StopBitsViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="1" Grid.Column="2" Classes="FormLabel" Text="校验位"/>
                <custom:ComboxControl Grid.Row="1"
                                      Grid.Column="3"
                                      ViewModel="{Binding GluePressureControlViewModel.ParityViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="1" Grid.Column="4" Classes="FormLabel" Text="Modbus类型"/>
                <custom:ComboxControl Grid.Row="1"
                                      Grid.Column="5"
                                      ViewModel="{Binding GluePressureControlViewModel.ModbusTypeViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Classes="FormLabel" Text="启用CRC16"/>
                <custom:ToggleSwitchControl Grid.Row="2"
                                            Grid.Column="1"
                                            ViewModel="{Binding GluePressureControlViewModel.EnableCRC16ViewModel}"
                                            LabelName=""
                                            WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="2" Grid.Column="2" Classes="FormLabel" Text="站号"/>
                <custom:TextInputControl Grid.Row="2"
                                         Grid.Column="3"
                                         ViewModel="{Binding GluePressureStationIdViewModel}"
                                         LabelName=""
                                         WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="2" Grid.Column="4" Classes="FormLabel" Text="通道号"/>
                <custom:TextInputControl Grid.Row="2"
                                         Grid.Column="5"
                                         ViewModel="{Binding GluePressureChannelIdViewModel}"
                                         LabelName=""
                                         WidthLevel="Small3"/>
                
                <TextBlock Grid.Row="3" Grid.Column="0" Classes="FormLabel" Text="胶量感应IO"/>
                <custom:ComboxControl Grid.Row="3"
                                      Grid.Column="1"
                                      ViewModel="{Binding GlueAmountStateIOViewModel.IOChannelViewModel}"
                                      LabelName=""
                                      WidthLevel="Small3"/>
              </Grid>
            </Border>
          </Grid>
        </Border>
        
      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
