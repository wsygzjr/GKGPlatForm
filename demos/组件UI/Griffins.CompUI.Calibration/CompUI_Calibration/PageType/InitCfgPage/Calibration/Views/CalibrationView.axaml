</UserControl.Resources>-->
           
	    <TabControl Margin="0" TabStripPlacement="Left"  BorderBrush="#CCCCCC" BorderThickness="1.5" Width="640"  MaxWidth="640" >

            <TabItem Header="偏移标定"> 
                <views:OffsetCalibrationView 
                    DataContext="{Binding OffsetCalibrationViewModel}"   BorderBrush="#CCCCCC" BorderThickness="1.5" 
                    />
            </TabItem>

             <TabItem Header="激光测高标定">
                <views:LaserAltimetryCalibrationView   
                    DataContext="{Binding LaserAltimetryCalibrationViewModel}"   BorderBrush="#CCCCCC" BorderThickness="1.5" 
                    />
            </TabItem>

             <TabItem Header="相机比例标定">
                <views:CameraRatioCalibrationView   
                    DataContext="{Binding CameraRatioCalibrationViewModel}"   BorderBrush="#CCCCCC" BorderThickness="1.5" 
                    />
            </TabItem>

             <TabItem Header="飞拍标定">
                <views:FlyingPhotoCalibrationView  
                    DataContext="{Binding FlyingPhotoCalibrationViewModel}"   BorderBrush="#CCCCCC" BorderThickness="1.5" 
                    />
            </TabItem>
        </TabControl>



</UserControl>
