<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<Company>Griffins</Company>
		<Copyright>Copyright © Griffins 2026</Copyright>
		<AssemblyVersion>7.1.0.0</AssemblyVersion>
		<FileVersion>7.1.0.0</FileVersion>
		<AssemblyTitle>Griffins.CompUI.Calibration</AssemblyTitle>
		<Product>Griffins.CompUI.Calibration</Product>
		<AssemblyName>Griffins.CompUI.Calibration</AssemblyName>
		<RootNamespace>Griffins.CompUI.Calibration</RootNamespace>
		<OutputType>Library</OutputType>
		<TargetFramework>net9.0</TargetFramework>
		<Nullable>disable</Nullable>
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
		<AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
		<OutputPath>F:\Griffins7.1\Bin\Share\CompUI\</OutputPath>
	</PropertyGroup>

  <ItemGroup>
    <Folder Include="Assets\" />
    <Folder Include="CompUI_Calibration\Models\" />
    <AvaloniaResource Include="Assets\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.3.3" ExcludeAssets="runtime" />
    <PackageReference Include="Avalonia.Desktop" Version="11.3.3" ExcludeAssets="runtime" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.3" ExcludeAssets="runtime" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="11.3.3" ExcludeAssets="runtime" />
    <PackageReference Include="AvaloniaUI.DiagnosticsSupport" Version="2.2.1">
      <IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
      <PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.1" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="ResourceA.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>ResourceA.resx</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="ResourceA.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>ResourceA.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

	<ItemGroup>
		<PackageReference Include="Griffins.ImeIOT" Version="7.1.0" ExcludeAssets="runtime" />
		<PackageReference Include="Griffins.ImeIOT.Map" Version="7.1.0" />
		<PackageReference Include="Griffins.UI2" Version="7.1.0" ExcludeAssets="runtime" />
		<PackageReference Include="Griffins.Map2" Version="7.1.0" ExcludeAssets="runtime" />
		<PackageReference Include="Griffins.Map.UI" Version="7.1.0" ExcludeAssets="runtime" />
		<PackageReference Include="Microsoft.CSharp" Version="4.7.0" ExcludeAssets="runtime" />
		<PackageReference Include="Newtonsoft.JsonG" Version="7.1.0" ExcludeAssets="runtime" />
		<PackageReference Include="Avalonia.ReactiveUI" Version="11.3.3" ExcludeAssets="runtime" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\公共引用\AvaloniaVisionControl\AvaloniaVisionControl.csproj" />
		<ProjectReference Include="..\公共引用\GKG.UI\GKG.UI.csproj" />
		<ProjectReference Include="..\公共引用\GKG\GKG.csproj" />
	</ItemGroup>

	<!-- 自定义目标：清理输出 -->

	<Target Name="CleanOutputDependencies" AfterTargets="Build">

		<ItemGroup>

			<!-- 要删除的 DLL 文件 -->

			<DllsToDelete Include="$(OutputPath)GKG.dll" />
			<DllsToDelete Include="$(OutputPath)GKG.UI.dll" />
			<DllsToDelete Include="$(OutputPath)AvaloniaVisionControl.dll" />
			<DllsToDelete Include="$(OutputPath)BasicRobotSubMachineModules.dll" />
			<DllsToDelete Include="$(OutputPath)CategoryARobotSubMachineModules.dll" />
			<DllsToDelete Include="$(OutputPath)DispensingFunctionHeadSubMachineModules.dll" />
			<DllsToDelete Include="$(OutputPath)GKG.ElectronicControl.dll" />
			<DllsToDelete Include="$(OutputPath)GKG.MotionControl.dll" />
			<DllsToDelete Include="$(OutputPath)PokaYoke.dll" />
			<DllsToDelete Include="$(OutputPath)WeighingBalanceSubMachineModules.dll" />
			<DllsToDelete Include="$(OutputPath)Valve.dll" />


			<!-- 要删除的 PDB 文件 -->

			<DllsToDelete Include="$(OutputPath)GKG.pdb" />
			<PdbsToDelete Include="$(OutputPath)GKG.UI.pdb" />
			<PdbsToDelete Include="$(OutputPath)AvaloniaVisionControl.pdb" />
			<DllsToDelete Include="$(OutputPath)BasicRobotSubMachineModules.pdb" />
			<PdbsToDelete Include="$(OutputPath)CategoryARobotSubMachineModules.pdb" />
			<PdbsToDelete Include="$(OutputPath)DispensingFunctionHeadSubMachineModules.pdb" />
			<DllsToDelete Include="$(OutputPath)GKG.ElectronicControl.pdb" />
			<PdbsToDelete Include="$(OutputPath)GKG.MotionControl.pdb" />
			<PdbsToDelete Include="$(OutputPath)PokaYoke.pdb" />
			<PdbsToDelete Include="$(OutputPath)Valve.pdb" />
			<PdbsToDelete Include="$(OutputPath)WeighingBalanceSubMachineModules.pdb" />



			<!-- 要删除的 XML 文件 -->

			<DllsToDelete Include="$(OutputPath)GKG.xml" />
			<XmlsToDelete Include="$(OutputPath)GKG.UI.xml" />
			<XmlsToDelete Include="$(OutputPath)AvaloniaVisionControl.xml" />



			<!-- 合并所有要删除的文件 -->

			<AllFilesToDelete Include="@(DllsToDelete)" />
			<AllFilesToDelete Include="@(PdbsToDelete)" />
			<AllFilesToDelete Include="@(XmlsToDelete)" />
		</ItemGroup>

		<!-- 删除文件 -->

		<Delete Files="@(AllFilesToDelete)" ContinueOnError="true" />
	</Target>
</Project>
