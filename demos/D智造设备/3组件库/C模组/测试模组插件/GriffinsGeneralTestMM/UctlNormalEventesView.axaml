<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             x:Class="GriffinsGeneralTestMM.UctlNormalEventesView"
             xmlns:vm="clr-namespace:GriffinsGeneralTestMM" 
             x:DataType="vm:UctlNormalEventesViewModel" 
        >

    
    <!-- 布局：ComboBox（顶部） + Button（下方） -->
 <Grid ColumnDefinitions="Auto,Auto,Auto"  Margin="20,10,0,5"  HorizontalAlignment="Stretch"  VerticalAlignment="Center" >
                                     
        <TextBlock Grid.Column="0"  Grid.Row="0" 
                Text="普通事件：" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Right"
                Margin="0 0 5 0"/>
        <!-- 事件选择   -->
        <ComboBox Grid.Column="1" Grid.Row="0"
                  ItemsSource="{Binding Events}"
                  SelectedItem="{Binding SelectedEvent}"
                  IsEnabled="True"  
                  HorizontalContentAlignment="Left"
                  VerticalContentAlignment="Center"  Width="282"/>

        <!-- 执行按钮 -->
        <Button Grid.Column="2" Grid.Row="0"
                Content="执行"   Width="110"  Classes="ButtonType1" 
                Margin="10 0 0 0"
                Command="{Binding ExecCommand}"
                IsEnabled="{Binding IsExecButtonEnabled}"/>
    </Grid>
</UserControl>