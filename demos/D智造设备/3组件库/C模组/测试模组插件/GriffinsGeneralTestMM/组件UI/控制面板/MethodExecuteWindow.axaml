<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1124" d:DesignHeight="805"  
        xmlns:views="clr-namespace:Griffins.UI.Test.Views;assembly=Griffins.UI.Test"   
        xmlns:vm="clr-namespace:GriffinsGeneralTestMM"
		x:DataType="vm:MethodExecuteWindowViewModel" 
        x:Class="GriffinsGeneralTestMM.MethodExecuteWindow"
        Title="执行命令">
     
              <views:MethodExecuteView DataContext="{Binding MethodExecuteViewModel}" Margin="0"/> 
       
</Window>
