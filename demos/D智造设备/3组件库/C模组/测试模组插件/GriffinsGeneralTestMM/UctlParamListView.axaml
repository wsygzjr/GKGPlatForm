<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="GriffinsGeneralTestMM.UctlParamListView"
               xmlns:vm="clr-namespace:GriffinsGeneralTestMM"
               x:DataType="vm:UctlParamListViewModel"
               d:DesignWidth="410" d:DesignHeight="267"> 

    <!-- 꽝鑒깊목썹충 -->

    <!-- 던버땡돨꽝鑒죗깊휭포 -->
    <ScrollViewer HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    Margin="5"  > 
      <!--코휭왠숭  zgl맣 -->    
           <ContentControl Content="{Binding StackPanel_UctlParamList}" BorderBrush="#CCCCCC" BorderThickness="1.5"  />   
    </ScrollViewer> 
</UserControl>
 