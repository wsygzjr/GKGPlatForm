<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             xmlns:local="clr-namespace:GKG.Map.MapCell.Generic.Lable.ViewModel"
             xmlns:converts="clr-namespace:GKG.Map.MapCell.Generic.Lable.Convert"
             x:Class="GKG.Map.MapCell.Generic.Lable.View.LableView"
             x:DataType="local:LableViewModel"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <UserControl.Resources>
        <converts:ColorToBrushConverter x:Key="ColorToBrushConverter" />
    </UserControl.Resources>

    <Border x:Name="RootBorder"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <TextBlock x:Name="Lable"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Center">
        </TextBlock>
    </Border>

</UserControl>
