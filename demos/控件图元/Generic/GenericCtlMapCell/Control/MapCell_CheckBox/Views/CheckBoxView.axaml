<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignWidth="200" 
             d:DesignHeight="30"
             xmlns:local="clr-namespace:GKG.Map.MapCell.Generic.CheckBox.ViewModel"
             x:Class="GKG.Map.MapCell.Generic.CheckBox.View.CheckBoxView"
             x:DataType="local:CheckBoxViewModel">
    
    <Grid x:Name="ContentHost">
        <Border x:Name="BackBorder" />
        <CheckBox x:Name="CheckBoxCtl" 
                  Content="复选框"
                  HorizontalAlignment="Stretch" 
                  VerticalAlignment="Stretch">
        </CheckBox>
    </Grid>
    
</UserControl>
