<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignWidth="200" 
             d:DesignHeight="30"
             xmlns:local="clr-namespace:GKG.Map.MapCell.Generic.ProgressBar.ViewModel"
             x:Class="GKG.Map.MapCell.Generic.ProgressBar.View.ProgressBarView"
             x:DataType="local:ProgressBarViewModel">

    <Grid x:Name="ContentHost">
        <Border x:Name="BackBorder" />
        <ProgressBar x:Name="ProgressBarCtl" />
        <TextBlock x:Name="TextCtl" HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>

</UserControl>
