<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GKG.Map.LoadUnloadFuncCtlMapCell.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="200"
             x:Class="GKG.Map.LoadUnloadFuncCtlMapCell.Views.LoadUnloadValueMapOprtCellParamView"
             x:DataType="vm:LoadUnloadValueMapOprtCellParamViewModel">
    
    <Design.DataContext>
        <vm:LoadUnloadValueMapOprtCellParamViewModel />
    </Design.DataContext>

    <Border Padding="20" Background="Transparent">
        <StackPanel Spacing="16">
            
            <!-- 第一行：配置开关 -->
            <CheckBox Content="是否显示单位" 
                      IsChecked="{Binding ShowUnit}" 
                      FontWeight="SemiBold"
                      ToolTip.Tip="勾选后，图元将在界面上显示下方配置的单位" />
            
            <!-- 第二行：具体参数输入 (加入 UI 防呆联动逻辑) -->
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="单位标识：" Width="70" VerticalAlignment="Center" Foreground="#4B5563" />
                
                <!-- 防呆联动禁用。如果不勾选显示，输入框自动禁用变灰 -->
                <TextBox Text="{Binding Unit}" 
                         Width="120" 
                         IsEnabled="{Binding ShowUnit}"
                         Watermark="例如: pcs, mm"
                         VerticalContentAlignment="Center" />
            </StackPanel>
            
        </StackPanel>
    </Border>
</UserControl>