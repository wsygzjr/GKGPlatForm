<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GKG.Map.ProductionInformationFuncCtlMapCell.ViewModel"
        xmlns:models="using:GKG.Map.ProductionInformationFuncCtlMapCell.Models"
        x:Class="GKG.Map.ProductionInformationFuncCtlMapCell.View.MachineStatusRecordView"
        x:DataType="vm:MachineStatusRecordViewModel"
        x:CompileBindings="True"
        Title="设备运行状态记录" Width="900" Height="550"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F9">


    <Window.Resources>
        <StreamGeometry x:Key="Icon_Calendar">
            M 4 2 C 2.89 2 2 2.89 2 4 v 16 c 0 1.11 .89 2 2 2 h 16 c 1.11 0 2 -.89 2 -2 v -16 c 0 -1.11 -.89 -2 -2 -2 h -3 v -1 c 0 -1.11 -.89 -2 -2 -2 s -2 .89 -2 2 v 1 h -2 v -1 c 0 -1.11 -.89 -2 -2 -2 s -2 .89 -2 2 v 1 H 4 m 1 1 h 2 v 1 H 4 V 3 m 12 0 h 2 v 1 h -2 V 3 m -13 4 h 16 v 12 H 3 V 7 m 3 3 h 4 v 2 H 6 V 10 m 6 0 h 4 v 2 H 12 V 10 m -6 4 h 4 v 2 H 6 V 14 m 6 0 h 4 v 2 H 12 V 14 Z
        </StreamGeometry>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="DataGridRow:nth-child(2n)">
            <Setter Property="Background" Value="#FAFAFA"/>
        </Style>
        <Style Selector="DataGridRow:nth-child(2n+1)">
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#E6F4FF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
        </Style>
        
        <Style Selector="DataGridCell">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style Selector="CalendarDatePicker.IconOnly">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="Transparent"/>
            
            <Style Selector="^ /template/ TextBox#PART_TextBox">
                <Setter Property="IsVisible" Value="False"/>
            </Style>
            
            <Style Selector="^ /template/ Button#PART_Button">
                <Setter Property="Margin" Value="0"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Setter Property="Opacity" Value="0.01"/>
                <Setter Property="Background" Value="Transparent"/>
            </Style>

            <Style Selector="^ /template/ Button#PART_Button Path">
                <Setter Property="IsVisible" Value="False"/>
            </Style>
            <Style Selector="^ /template/ Button#PART_Button TextBlock">
                <Setter Property="IsVisible" Value="False"/>
            </Style>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, *">
        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="White" Height="70" Padding="20,0" BoxShadow="0 2 5 0 #15000000">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="20">
                
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="开始日期:" VerticalAlignment="Center" Foreground="#333333"/>
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Background="White" Height="36">
                        <Grid ColumnDefinitions="90, Auto, 36">
                            <TextBlock Grid.Column="0" Text="{Binding OffsetStartDate, StringFormat={}{0:yyyy-MM-dd}}" 
                                       VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#333333"/>
                            
                            <Rectangle Grid.Column="1" Width="1" Fill="#E0E0E0" Margin="0,6"/>
                            
                            <Grid Grid.Column="2" Cursor="Hand" Background="Transparent">
                                <PathIcon Data="{StaticResource Icon_Calendar}" Width="18" Height="18" Foreground="#0078D4" IsHitTestVisible="False"/>
                                <CalendarDatePicker Classes="IconOnly" SelectedDate="{Binding OffsetStartDate, Mode=TwoWay}" ToolTip.Tip="点击选择日期"/>
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>

                <TextBlock Text="至" VerticalAlignment="Center" Foreground="#666666" Margin="5,0"/>

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="结束日期:" VerticalAlignment="Center" Foreground="#333333"/>
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Background="White" Height="36">
                        <Grid ColumnDefinitions="90, Auto, 36">
                            <TextBlock Grid.Column="0" Text="{Binding OffsetEndDate, StringFormat={}{0:yyyy-MM-dd}}" 
                                       VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#333333"/>
                            
                            <Rectangle Grid.Column="1" Width="1" Fill="#E0E0E0" Margin="0,6"/>
                            
                            <Grid Grid.Column="2" Cursor="Hand" Background="Transparent">
                                <PathIcon Data="{StaticResource Icon_Calendar}" Width="18" Height="18" Foreground="#0078D4" IsHitTestVisible="False"/>
                                <CalendarDatePicker Classes="IconOnly" SelectedDate="{Binding OffsetEndDate, Mode=TwoWay}" ToolTip.Tip="点击选择日期"/>
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>

                <Separator Width="1" Height="30" Background="#E0E0E0" Margin="10,0"/>

                <Button Content="查询区间" 
                        Command="{Binding RefreshCommand}"
                        Width="100" Height="36"
                        Background="#0078D4" Foreground="White" Cursor="Hand"
                        VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                <Button Content="今日数据" 
                        Command="{Binding RefreshTodayCommand}"
                        Width="100" Height="36"
                        Background="White" BorderBrush="#0078D4" BorderThickness="1" Foreground="#0078D4" Cursor="Hand"
                        VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 数据表格 -->
        <Border Grid.Row="1" Margin="20" CornerRadius="8" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding MachineStatusList}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="All">
                <DataGrid.Columns>
                    <!-- 架构优化：为每一列显式指定数据类型，打通强类型编译时绑定 -->
                    <DataGridTextColumn Header="状态类别" x:DataType="models:MachineStatusStatistics" Binding="{Binding Type}" Width="*" />
                    <DataGridTextColumn Header="持续时间 (hh:mm:ss)" x:DataType="models:MachineStatusStatistics" Binding="{Binding Time}" Width="*" />
                    <DataGridTextColumn Header="触发次数" x:DataType="models:MachineStatusStatistics" Binding="{Binding Count}" Width="*" />
                    <DataGridTextColumn Header="时间占比 (%)" x:DataType="models:MachineStatusStatistics" Binding="{Binding Percentage}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>