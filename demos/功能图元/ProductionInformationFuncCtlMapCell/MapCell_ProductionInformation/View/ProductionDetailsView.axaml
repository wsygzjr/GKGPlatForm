<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GKG.Map.ProductionInformationFuncCtlMapCell.ViewModel"
        xmlns:models="using:GKG.Map.ProductionInformationFuncCtlMapCell.Models"
        x:Class="GKG.Map.ProductionInformationFuncCtlMapCell.View.ProductionDetailsView"
        x:DataType="vm:ProductionDetailsViewModel"
        x:CompileBindings="True"
        Title="生产详情记录"
        Icon="/Assets/Images/logo.ico"
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F9">

    <Window.Styles>
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="DataGridRow:nth-child(2n)">
            <Setter Property="Background" Value="#FAFAFA"/>
        </Style>
        <Style Selector="DataGridRow:nth-child(2n+1)">
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#E6F4FF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style Selector="DataGridCell">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style Selector="Calendar">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="Auto, *" Margin="20">

        <!-- 左侧日历选择区 -->
        <Border Grid.Column="0"
                Background="White"
                CornerRadius="8"
                BoxShadow="0 2 5 0 #15000000"
                Margin="0,0,20,0"
                VerticalAlignment="Stretch">

            <StackPanel Margin="15">
                <TextBlock Text="选择查询日期"
                           FontWeight="Bold" FontSize="16" Foreground="#333333"
                           Margin="0,5,0,15" HorizontalAlignment="Center"/>

                <Calendar SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                          SelectionMode="SingleDate"
                          HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 右侧数据表格区 -->
        <Border Grid.Column="1"
                CornerRadius="8"
                ClipToBounds="True"
                BoxShadow="0 2 5 0 #15000000">

            <DataGrid ItemsSource="{Binding ProductionItems}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="All"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True">
                <DataGrid.Columns>
                    <!-- 架构优化：为每一列显式指定数据类型，打通强类型编译时绑定 -->
                    <DataGridTextColumn Header="时间区间" x:DataType="models:ProductionDetails" Binding="{Binding TimeInterval}" Width="1.5*" />
                    <DataGridTextColumn Header="程序名称" x:DataType="models:ProductionDetails" Binding="{Binding ProgramName}"  Width="2*" />
                    <DataGridTextColumn Header="生产整板数量" x:DataType="models:ProductionDetails" Binding="{Binding BigPcs}"  Width="1.5*" />
                    <DataGridTextColumn Header="生产子板数量" x:DataType="models:ProductionDetails" Binding="{Binding SmallPcs}" Width="1.5*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>