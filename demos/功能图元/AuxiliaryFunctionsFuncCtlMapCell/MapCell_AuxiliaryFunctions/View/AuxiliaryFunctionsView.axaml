<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
			 x:Class="GKG.Map.AuxiliaryFunctionsFuncCtlMapCell.View.AuxiliaryFunctionsView">
	<Grid>
		<Grid.Styles>
			<Style Selector="Button.BlueBtn">
				<Setter Property="Width" Value="150"/>
				<Setter Property="Height" Value="60"/>
				<Setter Property="Background" Value="#5B9BD5"/> <Setter Property="Foreground" Value="White"/>
				<Setter Property="FontSize" Value="16"/>
				<Setter Property="HorizontalAlignment" Value="Center"/>
				<Setter Property="VerticalAlignment" Value="Center"/>
				<Setter Property="HorizontalContentAlignment" Value="Center"/>
				<Setter Property="VerticalContentAlignment" Value="Center"/>
				<Setter Property="Margin" Value="0,0,10,0"/> </Style>
			<Style Selector="Button.BlueBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
				<Setter Property="Background" Value="#4A88C5"/>
				<Setter Property="TextBlock.Foreground" Value="White"/>
			</Style>

			<Style Selector="Button.SettingBtn">
				<Setter Property="Width" Value="45"/>
				<Setter Property="Height" Value="35"/>
				<Setter Property="Background" Value="Transparent"/>
				<Setter Property="Foreground" Value="#4A90E2"/>
				<Setter Property="FontSize" Value="20"/>
				<Setter Property="BorderThickness" Value="0"/>
				<Setter Property="HorizontalAlignment" Value="Center"/>
				<Setter Property="VerticalAlignment" Value="Center"/>
				<Setter Property="HorizontalContentAlignment" Value="Center"/>
				<Setter Property="VerticalContentAlignment" Value="Center"/>
				<Setter Property="Padding" Value="0,0,0,0"/>
				<Setter Property="Cursor" Value="Hand"/>
			</Style>
			<Style Selector="Button.SettingBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
				<Setter Property="Background" Value="Transparent"/>
				<Setter Property="TextBlock.Foreground" Value="#005A9E"/>
			</Style>
		</Grid.Styles>

		<Border BorderThickness="1" BorderBrush="#E0E0E0" Background="White">
			<Grid x:Name="m_gridTiAssistFunc" Margin="10,10,10,10">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="#F0F0F0" Padding="0,10">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="155"/>
							<ColumnDefinition Width="60"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Button Name="OneKeyTransferGlueButton" Classes="BlueBtn" Content="一键换胶" Grid.Column="0" />
						<Button Name="OneKeyTransferGlueSetButton" Classes="SettingBtn" Content="⚙" Grid.Column="1" ToolTip.Tip="一键换胶设置"/>

						<StackPanel Grid.Column="2" Orientation="Horizontal">
							<Button Name="TransferGluePosButton" Classes="BlueBtn" Content="换胶位置" />
							<Button Name="LeftValveOutGlueButton" Classes="BlueBtn" Content="左阀排胶" />
							<Button Name="RightValveOutGlueButton" Classes="BlueBtn" Content="右阀排胶" />
						</StackPanel>
					</Grid>
				</Border>

				<Border Grid.Row="1" BorderThickness="0,0,0,1" BorderBrush="#F0F0F0" Padding="0,10">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="155"/>
							<ColumnDefinition Width="60"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Button Name="OneKeyMachineCalibrationButton" Classes="BlueBtn" Content="一键校正" Grid.Column="0" />
						<Button Name="OneKeyMachineCalibrationSetButton" Classes="SettingBtn" Content="⚙" Grid.Column="1" ToolTip.Tip="一键校正设置"/>

						<StackPanel Grid.Column="2" Orientation="Horizontal">
							<Button Name="GlueTimerManageButton" Classes="BlueBtn" Content="胶水管理"/>
						</StackPanel>
					</Grid>
				</Border>

				<Border Grid.Row="2" BorderThickness="0,0,0,1" BorderBrush="#F0F0F0" Padding="0,10">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="155"/>
							<ColumnDefinition Width="60"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Button Name="OneKeyOutGlueButton" Classes="BlueBtn" Content="一键排胶" Grid.Column="0" />
						<Button Name="OneKeyOutGlueSetButton" Classes="SettingBtn" Content="⚙" Grid.Column="1" ToolTip.Tip="一键排胶设置"/>

						<StackPanel Grid.Column="2" Orientation="Horizontal">
							<Button Name="TransferValvePosButton" Classes="BlueBtn" Content="拆阀位置" />
							<Button Name="ValveAlarmResetButton" Classes="BlueBtn" Content="阀报警复位"/>
						</StackPanel>
					</Grid>
				</Border>

				<Border Grid.Row="3" BorderThickness="0,0,0,1" BorderBrush="#F0F0F0" Padding="0,10">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="155"/>
							<ColumnDefinition Width="60"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Button Name="OneKeyOutWaxButton" Classes="BlueBtn" Content="一键排蜡" Grid.Column="0" />
						<Button Name="OneKeyOutWaxSetButton" Classes="SettingBtn" Content="⚙" Grid.Column="1" ToolTip.Tip="一键排蜡设置"/>
					</Grid>
				</Border>

			</Grid>
		</Border>
	</Grid>
</UserControl>
