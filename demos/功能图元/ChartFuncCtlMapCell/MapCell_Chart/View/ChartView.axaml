<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
             xmlns:vm="using:GKG.Map.ChartFuncCtlMapCell.ViewModel"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="GKG.Map.ChartFuncCtlMapCell.View.ChartView"
             x:DataType="vm:ChartViewModel"
             Background="Transparent"> <UserControl.Styles>
        <StyleInclude Source="avares://GKG.Map.ChartFuncCtlMapCell/Styles/ControlStyles.axaml" />
        
        <Style Selector="TextBlock.Label">
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.Value">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Grid Name="grid_WeightChart_Line" RowDefinitions="Auto, *, Auto" Margin="16">

        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="20,16" Margin="0,0,0,16"
                BoxShadow="0 2 10 0 #0A000000" BorderBrush="#EAECEF" BorderThickness="1">
            
            <Grid ColumnDefinitions="Auto, *, Auto">
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Classes="Label" Text="图表类型：" FontWeight="Bold" />

                    <ComboBox Name="ChartTypeComboBox"
                              Width="200" Height="32" 
                              VerticalAlignment="Center"
                              Background="#F8F9FA"
                              FontFamily="Microsoft YaHei UI">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Border Width="1" Height="20" Background="#E0E0E0" Margin="4,0"/>

                    <Button Name="RefreshChartButton" Classes="Blue" Content="刷 新" Width="80" Height="32" CornerRadius="4"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Classes="Label" Text="CPK:"/>
                        <TextBlock Name="ChartCpkTextBlock" Classes="Value" Text="0.000" Foreground="#0078D4"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Classes="Label" Text="上限:"/>
                        <TextBlock Name="ChartUpperLimitValueTextBlock" Classes="Value" Text="0.00" Foreground="#D32F2F"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Classes="Label" Text="下限:"/>
                        <TextBlock Name="ChartLowerLimitValueTextBlock" Classes="Value" Text="0.00" Foreground="#388E3C"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="plotToCopy" Grid.Row="1" 
                Background="White" CornerRadius="8" Padding="12"
                BoxShadow="0 2 10 0 #0A000000" BorderBrush="#EAECEF" BorderThickness="1">
            <sp:AvaPlot Name="TodayPlot" />
        </Border>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            
            <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Left">
                <Button Name="HistoryChartButton" Content="查询历史图表" 
                        Height="34" Padding="20,0" CornerRadius="4" 
                        VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                        Background="#F0F8FF" Foreground="#0078D4" BorderBrush="#BBDEFB" BorderThickness="1" Cursor="Hand"/>
                
                <Button Name="OpenFileButton" Content="打开文件位置" 
                        Height="34" Padding="20,0" CornerRadius="4" 
                        VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                        Background="#F8F9FA" Foreground="#333333" BorderBrush="#D1D5DB" BorderThickness="1" Cursor="Hand"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Name="CleanButton" Content="清除今日数据" 
                        Height="34" Padding="20,0" CornerRadius="4" 
                        VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                        Background="#FFF0F0" Foreground="#D32F2F" BorderBrush="#FFCDD2" BorderThickness="1" Cursor="Hand"/>
            </StackPanel>

        </Grid>
    </Grid>

</UserControl>