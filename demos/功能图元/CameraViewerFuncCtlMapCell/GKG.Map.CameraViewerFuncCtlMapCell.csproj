		<ItemGroup>
			<!--<_DllsToKeep Include="@(ReferenceCopyLocalPaths)" Condition="'%(Filename)' == 'ReactiveUI.Fody.Helpers'" />-->

			<ReferenceCopyLocalPaths Remove="@(ReferenceCopyLocalPaths)" />

			<ReferenceCopyLocalPaths Include="@(_DllsToKeep)" />
		</ItemGroup>
	</Target>

	<ItemGroup>
		<None Remove="Assets\Images\**" />

		<AvaloniaResource Include="Assets\Images\**" />
	</ItemGroup>

	<ItemGroup>
		<Compile Update="MapCell_CameraViewer\View\CameraViewerValueMapOprtCellParamView.axaml.cs">
